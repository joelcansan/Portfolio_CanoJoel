---
// ContactForm.astro
// Dos vías de contacto:
// 1. Formulario (EmailJS) — configura las 3 constantes abajo para activarlo
// 2. Botón mailto directo → abre el cliente de correo ya con joelcanosan@gmail.com
---

<div class="contact-wrap">

  <div class="cf-header reveal-up" data-reveal>
    <p class="section-label">// Contacto</p>
    <h2 class="cf-title">¿Hablamos?</h2>
    <p class="cf-subtitle">
      ¿Tienes un proyecto, una oferta o quieres saludar?
      Escríbeme y te respondo en menos de 24h.
    </p>
  </div>

  <div class="cf-grid">

    <!-- ── Formulario ── -->
    <form class="cf-form reveal-up reveal-delay-1" data-reveal id="contact-form" novalidate
      action="https://formspree.io/f/mzdwrbbw" method="POST">
      <div id="form-status" class="form-status" aria-live="polite"></div>

      <div class="form-row">
        <div class="form-group">
          <label for="cf-name" class="form-label"><span class="lbl-num">01</span> Nombre</label>
          <input type="text" id="cf-name" name="from_name" class="form-input" placeholder="Tu nombre" required autocomplete="name" />
          <span class="field-err" data-for="cf-name"></span>
        </div>
        <div class="form-group">
          <label for="cf-email" class="form-label"><span class="lbl-num">02</span> Email</label>
          <input type="email" id="cf-email" name="reply_to" class="form-input" placeholder="tu@email.com" required autocomplete="email" />
          <span class="field-err" data-for="cf-email"></span>
        </div>
      </div>

      <div class="form-group">
        <label for="cf-subject" class="form-label"><span class="lbl-num">03</span> Asunto</label>
        <input type="text" id="cf-subject" name="subject" class="form-input" placeholder="¿De qué va?" required />
        <span class="field-err" data-for="cf-subject"></span>
      </div>

      <div class="form-group">
        <label for="cf-message" class="form-label"><span class="lbl-num">04</span> Mensaje</label>
        <textarea id="cf-message" name="message" class="form-input form-textarea" placeholder="Cuéntame..." rows="5" required></textarea>
        <span class="field-err" data-for="cf-message"></span>
      </div>

      <!-- Botones -->
      <div class="cf-actions">
        <button type="submit" class="cf-btn" id="form-submit">
          <span class="btn-text">Enviar mensaje</span>
          <span class="btn-ico">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </span>
          <span class="btn-dots" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>

        <!-- Botón mailto directo -->
        <a
          href="mailto:joelcanosan@gmail.com?subject=Contacto%20desde%20portfolio"
          class="cf-mailto"
          title="Abrir cliente de correo"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          Abrir en mi correo
        </a>
      </div>
    </form>

    <!-- ── Aside info ── -->
    <aside class="cf-aside reveal-right reveal-delay-2" data-reveal>

      <div class="aside-block">
        <p class="aside-label">// Email directo</p>
        <a href="mailto:joelcanosan@gmail.com" class="aside-val aside-email">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          joelcanosan@gmail.com
        </a>
      </div>

      <div class="aside-block">
        <p class="aside-label">// GitHub</p>
        <a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer" class="aside-val">
          github.com/joelcansan
        </a>
      </div>

      <div class="aside-block">
        <p class="aside-label">// LinkedIn</p>
        <a href="https://www.linkedin.com/in/joel-cano-sanchez-95198b2b4/" target="_blank" rel="noopener noreferrer" class="aside-val">
          Joel Cano Sánchez
        </a>
      </div>

      <div class="aside-block">
        <p class="aside-label">// Estado</p>
        <p class="aside-val availability">
          <span class="avail-dot"></span>
          Disponible para proyectos
        </p>
      </div>

      <div class="terminal" aria-hidden="true">
        <div class="term-bar">
          <span class="tdot red"></span><span class="tdot yellow"></span><span class="tdot green"></span>
        </div>
        <div class="term-body">
          <p><span class="t-p">$</span> <span class="t-c">git log --oneline</span></p>
          <p><span class="t-h">a3f2c1b</span> <span class="t-m">fix: responsive nav</span></p>
          <p><span class="t-h">9d84e0a</span> <span class="t-m">feat: dark mode</span></p>
          <p><span class="t-h">12bc773</span> <span class="t-m">init: portfolio v2</span></p>
          <p><span class="t-p">$</span> <span class="t-cur">▋</span></p>
        </div>
      </div>
    </aside>
  </div>
</div>

<script is:inline>
(function () {
  var form      = document.getElementById('contact-form');
  var submitBtn = document.getElementById('form-submit');
  var statusBox = document.getElementById('form-status');

  function validateField(input) {
    var err = document.querySelector('[data-for="' + input.id + '"]');
    if (!err) return true;
    if (!input.validity.valid) {
      err.textContent = input.type === 'email' ? 'Email inv\u00e1lido' : 'Campo obligatorio';
      input.classList.add('has-error');
      return false;
    }
    err.textContent = '';
    input.classList.remove('has-error');
    return true;
  }

  if (!form) return;

  form.querySelectorAll('.form-input').forEach(function (inp) {
    inp.addEventListener('blur', function () { validateField(inp); });
    inp.addEventListener('input', function () {
      if (inp.classList.contains('has-error')) validateField(inp);
    });
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();

    var inputs = Array.from(form.querySelectorAll('[required]'));
    if (!inputs.map(validateField).every(Boolean)) return;

    submitBtn.classList.add('loading');
    statusBox.className = 'form-status';
    statusBox.textContent = '';

    var data = new FormData(form);

    fetch('https://formspree.io/f/mzdwrbbw', {
      method: 'POST',
      body: data,
      headers: { 'Accept': 'application/json' }
    })
    .then(function (res) {
      if (res.ok) {
        statusBox.className = 'form-status status-ok';
        statusBox.innerHTML =
          '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>' +
          '\u00a1Mensaje enviado! Te respondo pronto.';
        form.reset();
      } else {
        return res.json().then(function (json) { throw json; });
      }
    })
    .catch(function () {
      statusBox.className = 'form-status status-err';
      statusBox.innerHTML =
        '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>' +
        'Error al enviar. Prueba el bot\u00f3n de abajo.';
    })
    .finally(function () {
      submitBtn.classList.remove('loading');
    });
  });
})();
</script>

<style>
  .contact-wrap { width: 100%; }

  .cf-header { margin-bottom: 2.5rem; }

  .cf-title {
    font-size: 1.8rem; font-weight: 800;
    margin-bottom: 0.4rem; color: var(--ink-0);
  }
  .cf-title::before { content: none; }

  .cf-subtitle {
    color: var(--ink-1); font-size: 0.9rem;
    line-height: 1.75; margin: 0; max-width: 50ch;
  }

  .cf-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: start;
  }

  /* ── Formulario ── */
  .cf-form { display: flex; flex-direction: column; gap: 1.2rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }

  .form-label {
    font-family: var(--mono); font-size: 0.7rem;
    color: var(--ink-2); letter-spacing: 0.1em;
    text-transform: uppercase; display: flex; align-items: center; gap: 0.5em;
  }
  .lbl-num { color: var(--sig); font-weight: 700; }

  .form-input {
    width: 100%; background: var(--surface-1);
    border: 1px solid var(--line); border-radius: var(--r-md);
    color: var(--ink-0); font-family: var(--sans); font-size: 0.9rem;
    padding: 0.7em 1em;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    outline: none; resize: none;
  }
  .form-input::placeholder { color: var(--ink-3); opacity: 1; }
  .form-input:focus { border-color: var(--line-hot); box-shadow: 0 0 0 3px rgba(0,232,122,0.06); background: var(--surface-2); }
  .form-input.has-error { border-color: rgba(255,80,80,0.5); box-shadow: 0 0 0 3px rgba(255,80,80,0.06); }
  .form-textarea { min-height: 120px; line-height: 1.65; }

  .field-err { font-family: var(--mono); font-size: 0.68rem; color: #ff6b6b; min-height: 1em; }

  /* ── Botones ── */
  .cf-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cf-btn {
    display: inline-flex; align-items: center; gap: 0.55em;
    padding: 0.7em 1.5em;
    background: var(--sig); color: var(--void);
    border: none; border-radius: var(--r-sm);
    font-family: var(--mono); font-size: 0.82rem; font-weight: 700;
    letter-spacing: 0.04em; cursor: pointer;
    transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
  }
  .cf-btn:hover { background: var(--sig-dim); box-shadow: 0 0 20px rgba(0,232,122,0.25); transform: translateY(-1px); }
  .cf-btn:active { transform: translateY(0); }

  /* Botón mailto */
  .cf-mailto {
    display: inline-flex; align-items: center; gap: 0.5em;
    padding: 0.7em 1.2em;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-family: var(--mono); font-size: 0.78rem;
    color: var(--ink-1); text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    white-space: nowrap;
  }
  .cf-mailto:hover {
    color: var(--sig); border-color: var(--line-hot);
    background: var(--sig-faint); opacity: 1;
  }

  /* Dots loader */
  .btn-dots { display: none; gap: 3px; align-items: center; }
  .btn-dots span { width: 4px; height: 4px; background: var(--void); border-radius: 50%; animation: dot-b 0.6s infinite alternate; }
  .btn-dots span:nth-child(2) { animation-delay: 0.15s; }
  .btn-dots span:nth-child(3) { animation-delay: 0.30s; }
  @keyframes dot-b { from { transform: translateY(0); } to { transform: translateY(-5px); } }
  .cf-btn.loading .btn-text, .cf-btn.loading .btn-ico { display: none; }
  .cf-btn.loading .btn-dots { display: flex; }
  .cf-btn.loading { pointer-events: none; opacity: 0.8; }

  /* Status */
  .form-status { display: none; align-items: center; gap: 0.5em; padding: 0.7em 1em; border-radius: var(--r-md); font-family: var(--mono); font-size: 0.78rem; border: 1px solid transparent; }
  .form-status:not(:empty) { display: flex; }
  .status-ok  { background: rgba(0,232,122,0.07);  border-color: rgba(0,232,122,0.25);  color: var(--sig); }
  .status-err { background: rgba(255,80,80,0.07);  border-color: rgba(255,80,80,0.25);  color: #ff6b6b; }

  /* ── Aside ── */
  .cf-aside { display: flex; flex-direction: column; gap: 1.5rem; }

  .aside-block { display: flex; flex-direction: column; gap: 0.25rem; }

  .aside-label { font-family: var(--mono); font-size: 0.68rem; color: var(--ink-3); letter-spacing: 0.1em; text-transform: uppercase; margin: 0; }

  .aside-val { font-family: var(--mono); font-size: 0.82rem; color: var(--ink-1); text-decoration: none; transition: color 0.2s; margin: 0; }
  a.aside-val:hover { color: var(--sig); opacity: 1; }

  .aside-email { display: flex; align-items: center; gap: 0.4em; }

  .availability { display: flex; align-items: center; gap: 0.5em; }
  .avail-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--sig); flex-shrink: 0; animation: pulse-a 2.2s ease-in-out infinite; }
  @keyframes pulse-a { 0%,100% { box-shadow: 0 0 0 0 rgba(0,232,122,0.4); } 50% { box-shadow: 0 0 0 6px rgba(0,232,122,0); } }

  .terminal { background: var(--surface-1); border: 1px solid var(--line); border-radius: var(--r-md); overflow: hidden; margin-top: 0.5rem; }
  .term-bar { background: var(--surface-2); padding: 0.55em 0.9em; display: flex; gap: 5px; align-items: center; border-bottom: 1px solid var(--line); }
  .tdot { width: 9px; height: 9px; border-radius: 50%; }
  .tdot.red    { background: #ff5f57; }
  .tdot.yellow { background: #febc2e; }
  .tdot.green  { background: #28c840; }
  .term-body { padding: 0.85em 1em; display: flex; flex-direction: column; gap: 0.2em; }
  .term-body p { margin: 0; font-family: var(--mono); font-size: 0.7rem; color: var(--ink-2); line-height: 1.5; }
  .t-p { color: var(--sig); font-weight: 700; }
  .t-c { color: var(--ink-1); }
  .t-h { color: #febc2e; }
  .t-m { color: var(--ink-2); }
  .t-cur { color: var(--sig); animation: blink-c 1.1s step-start infinite; }
  @keyframes blink-c { 50% { opacity: 0; } }

  @media (max-width: 860px) {
    .cf-grid { grid-template-columns: 1fr; }
    .cf-aside { flex-direction: row; flex-wrap: wrap; gap: 1.5rem; }
    .aside-block { min-width: 130px; }
    .terminal { display: none; }
  }
  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
    .cf-btn, .cf-mailto { width: 100%; justify-content: center; }
    .cf-actions { flex-direction: column; }
    .cf-aside { flex-direction: column; }
  }
</style>
