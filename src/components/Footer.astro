			<span class="footer-logo"><span class="bracket">[</span>JCS<span class="bracket">]</span></span>
			<span class="footer-copy">&copy; {today.getFullYear()} Joel Cano Sanchez</span>
		</div>
		<div class="social-links">
			<a href="https://github.com/joelcansan" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18">
