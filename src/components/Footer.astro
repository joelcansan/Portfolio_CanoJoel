---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<span class="footer-brand">
			<span class="bracket">[</span>JCS<span class="bracket">]</span>
		</span>

		<span class="footer-sep" aria-hidden="true"></span>

		<nav class="footer-links" aria-label="Links de contacto">
			<!-- GitHub -->
			<a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer" class="foot-link">
				<svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
				github/joelcanosan
			</a>

			<!-- LinkedIn -->
			<a href="https://www.linkedin.com/in/joel-cano-sanchez-95198b2b4/" target="_blank" rel="noopener noreferrer" class="foot-link">
				<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
				LinkedIn
			</a>

			<!-- CV -->
			<a href="/public/CV_CanoJoel.pdf" download="CV_CanoJoel.pdf" class="foot-link">
				<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
					<polyline points="7 10 12 15 17 10"/>
					<line x1="12" y1="15" x2="12" y2="3"/>
				</svg>
				Descargar CV
			</a>
		</nav>

		<span class="footer-copy">&copy; {year}</span>
	</div>
</footer>

<style>
	footer {
		background: #111820;
		border-top: 1px solid rgba(255,255,255,0.07);
		margin-top: 4rem;
		position: relative;
		z-index: 1;
	}

	.footer-inner {
		max-width: 980px;
		margin: 0 auto;
		padding: 1.1rem 1.25rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	/* [JCS] */
	.footer-brand {
		font-family: var(--font-mono);
		font-size: 0.88rem;
		font-weight: 700;
		color: #6b7f8c;
		flex-shrink: 0;
	}

	.bracket { color: var(--accent); }

	/* Separador vertical */
	.footer-sep {
		display: block;
		width: 1px;
		height: 14px;
		background: rgba(255,255,255,0.1);
		flex-shrink: 0;
	}

	/* Links */
	.footer-links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
		flex: 1;
		flex-wrap: wrap;
	}

	.foot-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.3em 0.7em;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		color: #4a5f70;
		text-decoration: none;
		border-radius: 4px;
		transition: color 0.2s, background 0.2s;
		white-space: nowrap;
	}

	.foot-link svg {
		color: #3d4a54;
		flex-shrink: 0;
		transition: color 0.2s;
	}

	.foot-link:hover {
		color: #8fa8bc;
		background: rgba(255,255,255,0.04);
	}

	.foot-link:hover svg {
		color: var(--accent);
	}

	/* Copyright */
	.footer-copy {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: #2d3d4a;
		margin-left: auto;
		flex-shrink: 0;
	}

	@media (max-width: 600px) {
		.footer-inner {
			gap: 0.75rem;
		}
		.footer-copy {
			margin-left: 0;
			width: 100%;
		}
	}
</style>
