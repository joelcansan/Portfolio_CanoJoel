---
import HeaderLink from './HeaderLink.astro';

const navLinks = [
  { href: '/',         label: 'Home',      i18n: 'nav.home' },
  { href: '/projects', label: 'Projects', i18n: 'nav.projects' },
  { href: '/about',    label: 'About',     i18n: 'nav.about' },
];
---

<!-- Skip to main content -->
<a href="#main-content" class="skip-link">Saltar al contenido principal</a>

<!-- Background blobs -->
<div id="bg-blobs" aria-hidden="true">
  <span></span>
  <span></span>
  <span></span>
</div>

<header class="hdr" id="site-header">
  <div class="hdr-inner">

    <!-- LOGO left: {JCS} + status -->
    <a href="/" class="hdr-logo" aria-label="Home">
      <span class="logo-brace">{</span><span class="logo-jcs">JCS</span><span class="logo-brace">}</span>
      <span class="logo-sep" aria-hidden="true"></span>
      <span class="logo-status">
        <span class="logo-status-dot" aria-hidden="true"></span>
        <span class="logo-status-text">online</span>
      </span>
    </a>

    <!-- NAV CENTER — pill -->
    <nav class="hdr-pill" aria-label="Navegación principal">
      {navLinks.map((link) => (
        <HeaderLink href={link.href} class="pill-link" data-i18n={link.i18n}>
          {link.label}
        </HeaderLink>
      ))}
    </nav>

    <!-- ACTIONS right -->
    <div class="hdr-actions">

      <!-- GitHub -->
      <a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer"
         class="act-icon" aria-label="Perfil de GitHub de Joel Cano (abre en nueva pestaña)" title="GitHub">
        <svg viewBox="0 0 16 16" width="17" height="17" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a href="https://www.linkedin.com/in/joel-cano-sanchez-95198b2b4/" target="_blank" rel="noopener noreferrer"
         class="act-icon" aria-label="Perfil de LinkedIn de Joel Cano (abre en nueva pestaña)" title="LinkedIn">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <!-- CV button with expand label on hover -->
      <a href="/CV_CanoJoel.pdf" download="CV_CanoJoel.pdf" class="act-cv" aria-label="Descargar CV de Joel Cano en PDF" title="Descargar CV">
        <svg class="cv-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <span class="cv-label" data-i18n="footer.cv">Descargar CV</span>
      </a>

      <!-- Lang -->
      <div class="act-lang" role="group" aria-label="Seleccionar idioma">
        <button type="button" class="lang-opt active" data-lang="es" onclick="setLanguage('es')" aria-pressed="true" aria-label="Cambiar idioma a español">ES</button>
        <span class="lang-div" aria-hidden="true">/</span>
        <button type="button" class="lang-opt" data-lang="en" onclick="setLanguage('en')" aria-pressed="false" aria-label="Switch language to English">EN</button>
      </div>

      <!-- Mobile burger -->
      <button type="button" class="hdr-burger" id="menu-toggle"
              aria-expanded="false" aria-controls="mobile-menu" aria-label="Abrir menú de navegación">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Scroll progress bar -->
  <div class="scroll-bar" id="scroll-bar" aria-hidden="true"></div>
</header>

<!-- MOBILE MENU overlay -->
<div class="mob-overlay" id="mobile-menu" aria-hidden="true">
  <div class="mob-inner">
    <button type="button" class="mob-close" id="mob-close" aria-label="Cerrar menú de navegación">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <nav class="mob-nav" aria-label="Navegación móvil">
      {navLinks.map((link, i) => (
        <HeaderLink href={link.href} class={`mob-link mob-link-${i}`} data-i18n={link.i18n}>
          <span class="mob-num">0{i + 1}</span>
          {link.label}
        </HeaderLink>
      ))}
    </nav>

    <div class="mob-foot">
      <a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer" aria-label="GitHub (abre en nueva pestaña)">GitHub</a>
      <a href="https://www.linkedin.com/in/joel-cano-sanchez-95198b2b4/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn (abre en nueva pestaña)">LinkedIn</a>
      <a href="/CV_CanoJoel.pdf" download aria-label="Descargar CV en PDF" data-i18n="footer.cv">Descargar CV</a>
    </div>

    <div class="mob-lang" role="group" aria-label="Seleccionar idioma">
      <button type="button" class="lang-opt active" data-lang="es" onclick="setLanguage('es')" aria-pressed="true" aria-label="Cambiar a español">ES</button>
      <span class="lang-div" aria-hidden="true">/</span>
      <button type="button" class="lang-opt" data-lang="en" onclick="setLanguage('en')" aria-pressed="false" aria-label="Switch to English">EN</button>
    </div>
  </div>
</div>

<script>
  const bar = document.getElementById('scroll-bar');
  if (bar) {
    window.addEventListener('scroll', () => {
      const h = document.documentElement;
      bar.style.width = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100 + '%';
    }, { passive: true });
  }

  const hdr = document.getElementById('site-header');
  if (hdr) {
    window.addEventListener('scroll', () => {
      hdr.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });
  }

  const toggle   = document.getElementById('menu-toggle');
  const overlay  = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mob-close');

  const openMenu  = () => {
    overlay?.classList.add('open');
    toggle?.setAttribute('aria-expanded','true');
    toggle?.setAttribute('aria-label', 'Cerrar menú de navegación');
    overlay?.setAttribute('aria-hidden','false');
    overlay?.removeAttribute('inert');
    document.body.classList.add('nav-open');
    /* Focus trap: mover foco al botón de cerrar */
    setTimeout(() => closeBtn?.focus(), 50);
  };
  const closeMenu = () => {
    overlay?.classList.remove('open');
    toggle?.setAttribute('aria-expanded','false');
    toggle?.setAttribute('aria-label', 'Abrir menú de navegación');
    overlay?.setAttribute('aria-hidden','true');
    overlay?.setAttribute('inert', '');
    document.body.classList.remove('nav-open');
    toggle?.focus();
  };

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.querySelectorAll('a').forEach(l => l.addEventListener('click', closeMenu));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMenu(); });
  window.addEventListener('resize', () => { if (window.innerWidth > 768) closeMenu(); });

  /* Actualizar aria-pressed en botones de idioma */
  window.addEventListener('DOMContentLoaded', () => {
    const updateAriaPressed = () => {
      document.querySelectorAll('.lang-opt').forEach(btn => {
        btn.setAttribute('aria-pressed', btn.classList.contains('active') ? 'true' : 'false');
      });
    };
    updateAriaPressed();
    /* Observar cambios de clase en los botones de idioma */
    const observer = new MutationObserver(updateAriaPressed);
    document.querySelectorAll('.lang-opt').forEach(btn => {
      observer.observe(btn, { attributes: true, attributeFilter: ['class'] });
    });
  });
</script>

<style>
  /* ══════════════════════════════════════════
     HEADER
     ══════════════════════════════════════════ */
  .hdr {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    background: transparent;
  }

  /* Glassmorphism background */
  .hdr::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(7, 9, 11, 0.82);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--line);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
    pointer-events: none;
  }

  .hdr.scrolled::before { opacity: 1; }

  .hdr-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    position: relative;
    z-index: 1;
    transition: padding 0.3s ease;
  }

  .hdr.scrolled .hdr-inner { padding: 0.6rem 1.25rem; }

  /* ── LOGO {JCS} online ── */
  .hdr-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .hdr-logo:hover { opacity: 1; }

  .logo-brace {
    font-family: var(--mono);
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--sig);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .logo-jcs {
    font-family: var(--mono);
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--ink-0);
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .hdr-logo:hover .logo-jcs { color: var(--sig); }

  .logo-sep {
    display: block;
    width: 1px;
    height: 16px;
    background: var(--line-mid);
    margin: 0 0.1rem;
    flex-shrink: 0;
  }

  .logo-status {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    padding: 0.18em 0.6em;
    background: rgba(0, 232, 122, 0.08);
    border: 1px solid rgba(0, 232, 122, 0.18);
    border-radius: 100px;
  }

  .logo-status-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--sig);
    animation: status-pulse 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes status-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0,232,122,0.5); }
    50%       { box-shadow: 0 0 0 4px rgba(0,232,122,0); }
  }

  .logo-status-text {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--sig);
    letter-spacing: 0.08em;
    text-transform: lowercase;
  }

  /* ── Center nav pill ── */
  .hdr-pill {
    display: flex;
    align-items: center;
    background: rgba(17, 24, 32, 0.7);
    border: 1px solid var(--line-mid);
    border-radius: 100px;
    padding: 0.3rem;
    backdrop-filter: blur(8px);
    position: relative;
    z-index: 1;
  }

  .hdr-pill :global(a.pill-link) {
    font-family: var(--mono);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--ink-2);
    text-decoration: none;
    padding: 0.45em 1em;
    border-radius: 100px;
    transition: color 0.2s, background 0.2s;
  }

  .hdr-pill :global(a.pill-link:hover) {
    color: var(--ink-0);
    background: rgba(255,255,255,0.06);
    opacity: 1;
    text-shadow: none;
  }

  .hdr-pill :global(a.pill-link.active) {
    color: var(--void);
    background: var(--sig);
    font-weight: 700;
  }

  /* ── Actions ── */
  .hdr-actions {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    position: relative;
    z-index: 1;
  }

  .act-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px; height: 34px;
    border-radius: 8px;
    border: 1px solid transparent;
    color: var(--ink-2);
    text-decoration: none;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }

  .act-icon:hover {
    color: var(--ink-0);
    background: rgba(255,255,255,0.05);
    border-color: var(--line);
    opacity: 1;
  }

  /* ── CV Button ── */
  .act-cv {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0;
    padding: 0 10px;
    height: 34px;
    overflow: hidden;
    background: var(--sig-faint);
    border: 1px solid var(--line-hot);
    border-radius: 6px;
    color: var(--sig);
    text-decoration: none;
    transition: background 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }

  .act-cv::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 232, 122, 0.12);
    transform: translateX(-101%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
    border-radius: 5px;
  }

  .act-cv:hover::after { transform: translateX(0); }

  .act-cv:hover {
    border-color: var(--line-hot);
    box-shadow: 0 0 14px rgba(0,232,122,0.2);
    opacity: 1;
  }

  .cv-icon {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 16px; height: 16px;
  }

  .cv-label {
    position: relative;
    z-index: 1;
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    white-space: nowrap;
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    transition:
      max-width 0.28s cubic-bezier(0.4, 0, 0.2, 1),
      opacity   0.18s ease 0.05s,
      margin-left 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    margin-left: 0;
  }

  .act-cv:hover .cv-label {
    max-width: 110px;
    opacity: 1;
    margin-left: 6px;
  }

  /* ── Lang ── */
  .act-lang {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    margin-left: 0.3rem;
    padding-left: 0.6rem;
    border-left: 1px solid var(--line);
  }

  .lang-opt {
    background: none; border: none; cursor: pointer;
    font-family: var(--mono); font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.04em; color: var(--ink-3);
    padding: 0.2em 0.35em; border-radius: 4px;
    transition: color 0.2s, background 0.2s;
  }
  .lang-opt:hover { color: var(--ink-1); }
  .lang-opt.active { color: var(--sig); background: var(--sig-faint); }

  .lang-div { font-family: var(--mono); font-size: 0.6rem; color: var(--ink-3); user-select: none; }

  /* ── Burger ── */
  .hdr-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px; height: 36px;
    padding: 0 9px;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 8px;
    cursor: pointer;
    margin-left: 0.4rem;
    transition: border-color 0.2s;
  }
  .hdr-burger:hover { border-color: var(--line-mid); }
  .hdr-burger span {
    display: block; width: 100%; height: 1.5px;
    background: var(--sig); border-radius: 1px;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }
  .hdr-burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hdr-burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hdr-burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Progress bar ── */
  .scroll-bar {
    position: absolute;
    bottom: 0; left: 0;
    height: 2px; width: 0%;
    background: linear-gradient(
      90deg,
      rgba(0, 184, 95, 0.25)  0%,
      rgba(0, 184, 95, 0.55) 25%,
      var(--sig-dim)         60%,
      var(--sig)            100%
    );
    transition: width 0.1s linear;
    box-shadow:
      0 0 6px  rgba(0, 232, 122, 0.25),
      0 0 14px rgba(0, 232, 122, 0.12);
  }

  /* ══════════════════════════════════════════
     MOBILE MENU overlay
     ══════════════════════════════════════════ */
  .mob-overlay {
    position: fixed; inset: 0; z-index: 500;
    background: rgba(7,9,11,0.97);
    backdrop-filter: blur(24px);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .mob-overlay.open { opacity: 1; pointer-events: all; }

  .mob-inner {
    display: flex; flex-direction: column; align-items: center; gap: 2rem;
    transform: translateY(20px);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    text-align: center;
  }
  .mob-overlay.open .mob-inner { transform: translateY(0); }

  .mob-close {
    position: absolute; top: 1.5rem; right: 1.5rem;
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    background: transparent; border: 1px solid var(--line); border-radius: 50%;
    color: var(--ink-1); cursor: pointer;
    transition: color 0.2s, border-color 0.2s, transform 0.2s;
  }
  .mob-close:hover { color: var(--sig); border-color: var(--line-hot); transform: rotate(90deg); }

  .mob-nav { display: flex; flex-direction: column; gap: 0.5rem; }

  .mob-nav :global(a.mob-link) {
    display: flex; align-items: center; gap: 1rem;
    font-family: var(--mono); font-size: clamp(1.6rem,5vw,2.5rem); font-weight: 800;
    color: var(--ink-2); text-decoration: none; letter-spacing: -0.03em;
    padding: 0.25em 1em; border-radius: 8px; transition: color 0.2s;
  }
  .mob-nav :global(a.mob-link:hover),
  .mob-nav :global(a.mob-link.active) { color: var(--sig); opacity: 1; text-shadow: 0 0 30px rgba(0,232,122,0.3); }

  .mob-num { font-size: 0.55em; color: var(--sig); opacity: 0.6; letter-spacing: 0.1em; align-self: flex-end; padding-bottom: 0.3em; }

  .mob-foot { display: flex; gap: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--line); }
  .mob-foot a { font-family: var(--mono); font-size: 0.8rem; color: var(--ink-2); text-decoration: none; transition: color 0.2s; }
  .mob-foot a:hover { color: var(--sig); opacity: 1; }

  .mob-lang { display: flex; align-items: center; gap: 0.3rem; }

  @media (max-width: 768px) {
    .hdr-pill { display: none; }
    .hdr-burger { display: flex; }
    .act-lang { display: none; }
  }
  @media (min-width: 769px) {
    .mob-overlay { display: none !important; }
  }
</style>
