---
import HeaderLink from './HeaderLink.astro';

const navLinks = [
	{ href: '/', label: 'Home', i18n: 'nav.home' },
	{ href: '/projects', label: 'Proyectos', i18n: 'nav.projects' },
	{ href: '/about', label: 'About', i18n: 'nav.about' },
];
---

<header class="site-header" id="site-header">
	<nav class="nav-bar" aria-label="Navegación principal">
		<div class="logo">
			<a href="/">
				<span class="logo-text">Portfolio</span>
			</a>
		</div>

		<div class="nav-desktop">
			<!-- Links de navegación con data-i18n para traducir -->
			<div class="internal-links">
				{navLinks.map((link) => (
					<HeaderLink href={link.href} data-i18n={link.i18n}>{link.label}</HeaderLink>
				))}
			</div>

			<!-- Links sociales -->
			<div class="social-links">
				<a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
					<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
						<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
					</svg>
				</a>
				<a href="https://www.linkedin.com/in/joel-cano-sanchez-95198b2b4/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" title="LinkedIn">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
					</svg>
				</a>
				<a href="/cv-joel-cano.pdf" download="CV_Joel_Cano_Sanchez.pdf" aria-label="Descargar CV" title="Descargar CV" class="cv-btn">
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="cv-icon">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
						<polyline points="7 10 12 15 17 10"/>
						<line x1="12" y1="15" x2="12" y2="3"/>
					</svg>
					<span class="cv-label">Descargar CV</span>
				</a>
			</div>

			<!--
				═══════════════════════════════════════
				SELECTOR DE IDIOMA (ES / EN)
				═══════════════════════════════════════
				Dos botones pequeños separados por una barra.
				Al hacer click llaman a setLanguage() del i18n.js
				La clase .active marca el idioma seleccionado.
			-->
			<div class="lang-selector" aria-label="Cambiar idioma">
				<button
					type="button"
					class="lang-option active"
					data-lang="es"
					onclick="setLanguage('es')"
					title="Español"
				>ES</button>
				<span class="lang-divider">/</span>
				<button
					type="button"
					class="lang-option"
					data-lang="en"
					onclick="setLanguage('en')"
					title="English"
				>EN</button>
			</div>
		</div>

		<button
			type="button"
			class="menu-toggle"
			id="menu-toggle"
			aria-expanded="false"
			aria-controls="mobile-menu"
			aria-label="Abrir menú de navegación"
		>
			<span class="hamburger" aria-hidden="true">
				<span class="hamburger-line"></span>
				<span class="hamburger-line"></span>
				<span class="hamburger-line"></span>
			</span>
		</button>
	</nav>

	<!-- Menú móvil -->
	<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
		<div class="mobile-menu-inner">
			<div class="mobile-links">
				{navLinks.map((link) => (
					<HeaderLink href={link.href} class="mobile-nav-link" data-i18n={link.i18n}>{link.label}</HeaderLink>
				))}
			</div>
			<div class="mobile-social">
				<a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a href="https://www.linkedin.com/in/joel-cano-sanchez-95198b2b4/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
				<a href="/public/CV_CanoJoel.pdf" download="CV_CanoJoel.pdf" aria-label="Descargar CV" data-i18n="footer.cv">Descargar CV</a>
			</div>
			<!-- Selector de idioma en móvil -->
			<div class="mobile-lang">
				<button type="button" class="lang-option active" data-lang="es" onclick="setLanguage('es')">ES</button>
				<span class="lang-divider">/</span>
				<button type="button" class="lang-option" data-lang="en" onclick="setLanguage('en')">EN</button>
			</div>
		</div>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const toggle = document.getElementById('menu-toggle');
	const menu = document.getElementById('mobile-menu');

	if (header && toggle && menu) {
		const openMenu = () => {
			header.classList.add('menu-open');
			toggle.setAttribute('aria-expanded', 'true');
			toggle.setAttribute('aria-label', 'Cerrar menú de navegación');
			menu.setAttribute('aria-hidden', 'false');
			document.body.classList.add('nav-open');
		};

		const closeMenu = () => {
			header.classList.remove('menu-open');
			toggle.setAttribute('aria-expanded', 'false');
			toggle.setAttribute('aria-label', 'Abrir menú de navegación');
			menu.setAttribute('aria-hidden', 'true');
			document.body.classList.remove('nav-open');
		};

		toggle.addEventListener('click', () => {
			if (header.classList.contains('menu-open')) {
				closeMenu();
			} else {
				openMenu();
			}
		});

		menu.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', closeMenu);
		});

		window.addEventListener('resize', () => {
			if (window.innerWidth > 768) closeMenu();
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') closeMenu();
		});
	}
</script>

<style>
	.site-header {
		margin: 0;
		padding: 0;
		background: #0f1c14;
		border-bottom: 1px solid rgba(0, 255, 136, 0.25);
		position: sticky;
		top: 0;
		z-index: 200;
	}

	.nav-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 60px;
		position: relative;
		z-index: 2;
		background: #0f1c14;
	}

	.logo a {
		text-decoration: none;
		display: flex;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 1.05em;
		font-weight: 700;
		color: var(--text-primary);
		text-shadow: none;
		transition: all 0.2s;
	}

	.logo a:hover {
		text-shadow: 0 0 12px rgba(0, 255, 136, 0.4);
	}

	.nav-desktop {
		display: flex;
		align-items: center;
		gap: 1.5em;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.2em;
	}

	.internal-links :global(a) {
		padding: 0.4em 0.8em;
		color: var(--text-secondary);
		text-decoration: none;
		font-family: var(--font-mono);
		font-size: 0.85em;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		font-weight: 500;
		border-radius: 6px;
		border: 1px solid transparent;
		transition: all 0.2s;
	}

	.internal-links :global(a:hover) {
		color: var(--accent);
		border-color: var(--border);
		background: var(--accent-glow);
		text-shadow: none;
	}

	.internal-links :global(a.active) {
		color: var(--accent);
		border-color: var(--border-hover);
		background: var(--accent-glow);
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 0.6em;
	}

	.social-links a {
		color: var(--text-muted);
		display: flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 6px;
		border: 1px solid transparent;
		transition: all 0.2s;
		text-decoration: none;
		text-shadow: none;
	}

	.social-links a:hover {
		color: var(--accent);
		border-color: var(--border);
		background: var(--accent-glow);
	}

	/* ── Botón CV ── */
	.cv-btn {
		position: relative;
		overflow: hidden;
		width: auto !important;
		padding: 0 10px !important;
		gap: 0 !important;
	}

	.cv-btn::after {
		content: '';
		position: absolute;
		inset: 0;
		background: var(--accent-glow);
		transform: translateX(-100%);
		transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 0;
		border-radius: 5px;
	}

	.cv-btn:hover::after {
		transform: translateX(0);
	}

	.cv-icon {
		position: relative;
		z-index: 1;
		flex-shrink: 0;
	}

	.cv-label {
		position: relative;
		z-index: 1;
		font-family: var(--font-mono);
		font-size: 0.78em;
		letter-spacing: 0.04em;
		white-space: nowrap;
		max-width: 0;
		opacity: 0;
		overflow: hidden;
		transition: max-width 0.28s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease 0.05s, margin-left 0.28s cubic-bezier(0.4, 0, 0.2, 1);
		margin-left: 0;
	}

	.cv-btn:hover .cv-label {
		max-width: 100px;
		opacity: 1;
		margin-left: 6px;
	}

	/* ══════════════════════════════════════
	   SELECTOR DE IDIOMA (ES / EN)
	   ══════════════════════════════════════
	   Dos botones con tipografía mono.
	   El activo brilla en verde accent,
	   el inactivo queda gris apagado.
	*/
	.lang-selector,
	.mobile-lang {
		display: flex;
		align-items: center;
		gap: 0.3em;
	}

	/* Cada botón de idioma */
	.lang-option {
		/* Reset del botón nativo */
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.2em 0.45em;
		border-radius: 4px;

		/* Tipografía mono, tamaño pequeño */
		font-family: var(--font-mono);
		font-size: 0.78em;
		font-weight: 600;
		letter-spacing: 0.04em;

		/* Color gris apagado por defecto */
		color: var(--text-muted);
		transition: color 0.2s ease, background 0.2s ease;
	}

	/* Hover en el botón inactivo */
	.lang-option:hover {
		color: var(--text-secondary);
		background: var(--accent-glow);
	}

	/* Botón del idioma activo: verde accent */
	.lang-option.active {
		color: var(--accent);
		background: rgba(0, 255, 136, 0.1);
	}

	/* La barrita separadora / entre ES y EN */
	.lang-divider {
		color: var(--text-muted);
		font-family: var(--font-mono);
		font-size: 0.75em;
		opacity: 0.4;
		user-select: none;
	}

	/* ── Hamburguesa (móvil) ── */
	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		padding: 0;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 8px;
		cursor: pointer;
		transition: border-color 0.2s, background 0.2s;
	}

	.menu-toggle:hover {
		border-color: var(--border-hover);
		background: var(--accent-glow);
	}

	.hamburger {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 20px;
	}

	.hamburger-line {
		display: block;
		width: 100%;
		height: 2px;
		background: var(--accent);
		border-radius: 2px;
		transition: transform 0.3s ease, opacity 0.3s ease;
		transform-origin: center;
	}

	.site-header.menu-open .hamburger-line:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.site-header.menu-open .hamburger-line:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}

	.site-header.menu-open .hamburger-line:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* ── Menú móvil ── */
	.mobile-menu {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		background: #0a1610;
		border-bottom: 1px solid transparent;
	}

	.site-header.menu-open .mobile-menu {
		max-height: 380px;
		border-bottom-color: rgba(0, 255, 136, 0.25);
	}

	.mobile-menu-inner {
		max-width: 960px;
		margin: 0 auto;
		padding: 0.5em 1.5em 1.25em;
		opacity: 0;
		transform: translateY(-8px);
		transition: opacity 0.3s ease 0.05s, transform 0.35s ease 0.05s;
	}

	.site-header.menu-open .mobile-menu-inner {
		opacity: 1;
		transform: translateY(0);
	}

	.mobile-links {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}

	.mobile-links :global(a.mobile-nav-link) {
		display: block;
		padding: 0.85em 1em;
		color: var(--text-secondary);
		text-decoration: none;
		font-family: var(--font-mono);
		font-size: 0.95em;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		border-radius: 8px;
		border: 1px solid transparent;
		transition: all 0.2s;
	}

	.mobile-links :global(a.mobile-nav-link:hover),
	.mobile-links :global(a.mobile-nav-link.active) {
		color: var(--accent);
		background: var(--accent-glow);
		border-color: var(--border);
		text-shadow: none;
	}

	.mobile-social {
		display: flex;
		gap: 1em;
		margin-top: 1em;
		padding-top: 1em;
		border-top: 1px solid var(--border);
	}

	.mobile-social a {
		font-family: var(--font-mono);
		font-size: 0.85em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.mobile-social a:hover {
		color: var(--accent);
		text-shadow: none;
	}

	/* Selector de idioma en el menú móvil */
	.mobile-lang {
		margin-top: 1em;
		padding-top: 1em;
		border-top: 1px solid var(--border);
		justify-content: center;
	}

	@media (max-width: 768px) {
		.nav-desktop {
			display: none;
		}

		.menu-toggle {
			display: flex;
		}
	}

	@media (min-width: 769px) {
		.mobile-menu {
			display: none !important;
		}
	}
</style>
