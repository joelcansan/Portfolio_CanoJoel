---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { titulo } from '../components/BaseHead.astro';

const stack = {
	frontend: ['JavaScript', 'React', 'Next.js', 'Astro', 'HTML', 'CSS', 'Tailwind'],
	backend: ['Node.js', 'Express', 'PHP', 'Laravel'],
	database: ['MySQL', 'MariaDB', 'MongoDB', 'Supabase'],
	tools: ['Git', 'SCRUM', 'REST APIs', 'WordPress', 'Docker'],
};

const timeline = [
	{
		period: '2022 — 2024',
		title: 'SMR',
		subtitle: 'Sistemas Microinformáticos y Redes',
		desc: 'Base sólida en hardware, redes y sistemas operativos.',
	},
	{
		period: '2024 — Actualidad',
		title: 'DAW',
		subtitle: 'Desarrollo de Aplicaciones Web',
		desc: 'Segundo curso. Full-stack, APIs, bases de datos y despliegue.',
	},
	{
		period: 'Becario',
		title: 'e-Corp Sistemas',
		subtitle: 'Montaje y sistemas',
		desc: 'Montaje de ordenadores, instalación y configuración de sistemas operativos.',
	},
	{
		period: 'Becario',
		title: 'Reactivació Badalona',
		subtitle: 'Desarrollo web',
		desc: 'WordPress, MariaDB, y stack moderno con React, Next.js, Tailwind, Laravel y Express.',
	},
];

const workCards = [
	{ tag: '// metodología', title: 'SCRUM', desc: 'Trabajo en equipo con sprints y entregas iterativas.' },
	{ tag: '// versionado', title: 'Git', desc: 'Control de versiones en todos mis proyectos personales y académicos.' },
	{ tag: '// deploy', title: 'En producción', desc: 'Vercel, Render, Railway y GitHub Pages.' },
];

const profile = {
	nombre: 'Joel Cano Sánchez',
	rol: 'Full-stack junior',
	edad: 19,
	estudios: '2º DAW',
	experiencia: ['e-Corp Sistemas', 'Reactivació Badalona'],
	disponible: true,
};

function renderProfileJson(p: typeof profile) {
	const experiencia = p.experiencia
		.map((empresa, i) => `    <span class="str">"${empresa}"</span>${i < p.experiencia.length - 1 ? ',' : ''}`)
		.join('\n');

	return `<span class="brace">{</span>
  <span class="key">"nombre"</span>: <span class="str">"${p.nombre}"</span>,
  <span class="key">"rol"</span>: <span class="str">"${p.rol}"</span>,
  <span class="key">"edad"</span>: <span class="num">${p.edad}</span>,
  <span class="key">"estudios"</span>: <span class="str">"${p.estudios}"</span>,
  <span class="key">"experiencia"</span>: [
${experiencia}
  ],
  <span class="key">"disponible"</span>: <span class="bool">${p.disponible}</span>
<span class="brace">}</span>`;
}
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`About | ${titulo}`} description="Conóceme: formación, experiencia y stack como desarrollador full-stack junior." />
		<style>
			/* ── Hero ── */
			.about-hero {
				padding: 1rem 0 0.5rem;
			}

			.hero-content {
				display: flex;
				align-items: center;
				gap: 3em;
			}

			.hero-photo {
				flex: 0 0 220px;
			}

			.hero-photo img {
				width: 220px;
				height: 220px;
				object-fit: cover;
				border-radius: 12px;
				border: 2px solid var(--border);
				box-shadow: var(--shadow-glow);
				background: var(--bg-card);
			}

			.hero-text {
				flex: 1;
			}

			.greeting {
				font-family: var(--font-mono);
				font-size: 0.9em;
				color: var(--accent);
				margin-bottom: 0.75em;
				letter-spacing: 0.05em;
			}

			.about-hero h1 {
				font-size: 2.6em;
				margin-bottom: 0.45em;
				line-height: 1.15;
			}

			.hero-sub {
				color: var(--text-secondary);
				font-size: 1.05em;
				max-width: 520px;
				margin-bottom: 2em;
				line-height: 1.8;
			}

			.cta-links {
				display: flex;
				gap: 0.8em;
				flex-wrap: wrap;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.55em 1.1em;
				border-radius: 6px;
				font-family: var(--font-mono);
				font-size: 0.85em;
				text-decoration: none;
				transition: all 0.2s;
			}

			.btn-primary {
				background: var(--accent);
				color: #0a0e0f;
				border: 1px solid var(--accent);
				font-weight: 600;
			}

			.btn-primary:hover {
				background: var(--accent-dim);
				border-color: var(--accent-dim);
				box-shadow: var(--shadow-glow);
				text-shadow: none;
				color: #0a0e0f;
			}

			.btn-outline {
				background: transparent;
				color: var(--text-secondary);
				border: 1px solid var(--border);
			}

			.btn-outline:hover {
				color: var(--accent);
				border-color: var(--border-hover);
				background: var(--accent-glow);
				text-shadow: none;
			}

			.divider {
				height: 1px;
				background: var(--border);
				margin: var(--section-gap) 0;
			}

			/* ── Stats bento ── */
			.stats-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1.25em;
			}

			.stat-card {
				padding: 1.2em 1.4em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
				transition: all 0.2s;
			}

			.stat-card:hover {
				border-color: var(--border-hover);
				box-shadow: var(--shadow-glow);
				transform: translateY(-2px);
			}

			.stat-value {
				font-family: var(--font-mono);
				font-size: 1.5em;
				font-weight: 700;
				color: var(--accent);
				margin-bottom: 0.2em;
			}

			.stat-label {
				font-family: var(--font-mono);
				font-size: 0.75em;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}

			/* ── Two columns: timeline + terminal ── */
			.content-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
				align-items: start;
			}

			.section-block .section-label {
				margin-bottom: 1.35rem;
			}

			/* Timeline */
			.timeline {
				list-style: none;
				padding: 0;
				margin: 0;
				position: relative;
			}

			.timeline::before {
				content: '';
				position: absolute;
				left: 7px;
				top: 8px;
				bottom: 8px;
				width: 2px;
				background: var(--border);
			}

			.timeline li {
				position: relative;
				padding-left: 2em;
				padding-bottom: 1.75em;
			}

			.timeline li:last-child {
				padding-bottom: 0;
			}

			.timeline li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 6px;
				width: 16px;
				height: 16px;
				border-radius: 50%;
				background: var(--bg-base);
				border: 2px solid var(--accent);
				box-shadow: 0 0 8px rgba(0, 255, 136, 0.3);
			}

			.timeline-period {
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--accent);
				letter-spacing: 0.05em;
				margin-bottom: 0.3em;
			}

			.timeline-title {
				font-family: var(--font-mono);
				font-size: 1em;
				font-weight: 600;
				color: var(--text-primary);
				margin: 0 0 0.15em;
			}

			.timeline-subtitle {
				font-size: 0.85em;
				color: var(--text-muted);
				margin: 0 0 0.4em;
			}

			.timeline-desc {
				font-size: 0.9em;
				color: var(--text-secondary);
				margin: 0;
				line-height: 1.6;
			}

			/* Terminal card */
			.terminal-card {
				background: var(--bg-elevated);
				border: 1px solid var(--border);
				border-radius: 10px;
				overflow: hidden;
			}

			.terminal-header {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 0.7em 1em;
				background: var(--bg-card);
				border-bottom: 1px solid var(--border);
			}

			.terminal-dot {
				width: 10px;
				height: 10px;
				border-radius: 50%;
			}

			.terminal-dot.red { background: #ff5f57; }
			.terminal-dot.yellow { background: #febc2e; }
			.terminal-dot.green { background: #28c840; }

			.terminal-filename {
				margin-left: 0.5em;
				font-family: var(--font-mono);
				font-size: 0.75em;
				color: var(--text-muted);
			}

			.terminal-body {
				padding: 1.2em 1.4em;
				font-family: var(--font-mono);
				font-size: 0.82em;
				line-height: 1.8;
				color: var(--text-secondary);
			}

			.terminal-body .brace { color: var(--text-primary); }
			.terminal-body .key { color: var(--accent); }
			.terminal-body .str { color: #7dd3a8; }
			.terminal-body .num { color: #f0ab6b; }
			.terminal-body .bool { color: #79b8ff; }

			/* ── Stack ── */
			.stack-section {
				margin-top: 0;
			}

			.stack-groups {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.25em;
			}

			.stack-group {
				padding: 1.2em 1.4em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
			}

			.stack-group h3 {
				font-size: 0.8em;
				color: var(--accent);
				margin-bottom: 0.8em;
				letter-spacing: 0.06em;
				text-transform: uppercase;
			}

			.stack-group h3::before {
				content: none;
			}

			.stack-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45em;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.stack-list li {
				padding: 0.28em 0.7em;
				background: var(--bg-elevated);
				border: 1px solid var(--border);
				border-radius: 4px;
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-secondary);
			}

			/* ── Work cards ── */
			.work-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25em;
			}

			.work-card {
				padding: 1.3em 1.4em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
				transition: all 0.2s;
			}

			.work-card:hover {
				border-color: var(--border-hover);
				box-shadow: var(--shadow-glow);
				transform: translateY(-2px);
			}

			.work-card .tag {
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--accent);
				margin-bottom: 0.5em;
			}

			.work-card h3 {
				font-size: 1em;
				margin-bottom: 0.4em;
			}

			.work-card h3::before {
				content: none;
			}

			.work-card p {
				margin: 0;
				font-size: 0.88em;
				line-height: 1.6;
			}

			/* ── Quote ── */
			.goal-quote {
				margin: 0;
				font-size: 1.05em;
				line-height: 1.75;
			}

			/* ── Responsive ── */
			@media (max-width: 768px) {
				.hero-content {
					flex-direction: column;
					text-align: center;
					gap: 2em;
				}

				.hero-sub {
					max-width: none;
				}

				.cta-links {
					justify-content: center;
				}

				.hero-photo img {
					width: 200px;
					height: 200px;
				}

				.stats-grid {
					grid-template-columns: repeat(2, 1fr);
				}

				.content-grid {
					grid-template-columns: 1fr;
					gap: 2.5rem;
				}

				.stack-groups {
					grid-template-columns: 1fr;
				}

				.work-grid {
					grid-template-columns: 1fr;
				}

				.about-hero h1 {
					font-size: 2.2em;
				}
			}

			@media (max-width: 480px) {
				.stats-grid {
					grid-template-columns: 1fr;
				}

				.about-hero h1 {
					font-size: 1.9em;
				}

				.hero-photo img {
					width: 180px;
					height: 180px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="about-hero">
				<div class="hero-content">
					<div class="hero-photo">
						<img src="/images/joelcano.png" alt="Foto de Joel Cano Sánchez" width="220" height="220" />
					</div>
					<div class="hero-text">
						<p class="greeting">// about_me</p>
						<h1>Joel Cano Sánchez</h1>
						<p class="hero-sub">
							Desarrollador <strong>full-stack junior</strong> con 19 años. Me apasiona crear
							aplicaciones desde cero, resolver problemas reales y ver cómo una idea se convierte
							en algo funcional.
						</p>
						<div class="cta-links">
							<a href="/projects" class="btn btn-primary">Ver proyectos →</a>
							<a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer" class="btn btn-outline">GitHub</a>
							<a
								href="https://mail.google.com/mail/u/0/#inbox?compose=DmwnWrRqhSDmLLzgvbLNwCpqvlxgScVFtWCklrDknzJcHhQnzxLrKwThxTMWqbKqbwXVmmpmDcvB"
								target="_blank"
								rel="noopener noreferrer"
								class="btn btn-outline"
							>Contacto</a>
						</div>
					</div>
				</div>
			</section>

			<div class="divider"></div>

			<!-- Stats -->
			<div class="stats-grid page-section">
				<div class="stat-card">
					<div class="stat-value">19</div>
					<div class="stat-label">Años</div>
				</div>
				<div class="stat-card">
					<div class="stat-value">2º</div>
					<div class="stat-label">DAW</div>
				</div>
				<div class="stat-card">
					<div class="stat-value">Full-stack</div>
					<div class="stat-label">Junior</div>
				</div>
				<div class="stat-card">
					<div class="stat-value">2</div>
					<div class="stat-label">Becarios</div>
				</div>
			</div>

			<div class="divider"></div>

			<!-- Timeline + Terminal -->
			<div class="content-grid page-section">
				<div>
					<p class="section-label">// Mi camino</p>
					<ul class="timeline">
						{timeline.map((item) => (
							<li>
								<p class="timeline-period">{item.period}</p>
								<h3 class="timeline-title">{item.title}</h3>
								<p class="timeline-subtitle">{item.subtitle}</p>
								<p class="timeline-desc">{item.desc}</p>
							</li>
						))}
					</ul>
				</div>
				<div>
					<p class="section-label">// joel.json</p>
					<div class="terminal-card">
						<div class="terminal-header">
							<span class="terminal-dot red"></span>
							<span class="terminal-dot yellow"></span>
							<span class="terminal-dot green"></span>
							<span class="terminal-filename">joel.json</span>
						</div>
						<pre class="terminal-body"><code set:html={renderProfileJson(profile)} /></pre>
					</div>
				</div>
			</div>

			<div class="divider"></div>

			<!-- Stack -->
			<section class="stack-section page-section section-block">
				<p class="section-label">// Stack</p>
				<div class="stack-groups">
					<div class="stack-group">
						<h3>Frontend</h3>
						<ul class="stack-list">
							{stack.frontend.map((tech) => <li>{tech}</li>)}
						</ul>
					</div>
					<div class="stack-group">
						<h3>Backend</h3>
						<ul class="stack-list">
							{stack.backend.map((tech) => <li>{tech}</li>)}
						</ul>
					</div>
					<div class="stack-group">
						<h3>Bases de datos</h3>
						<ul class="stack-list">
							{stack.database.map((tech) => <li>{tech}</li>)}
						</ul>
					</div>
					<div class="stack-group">
						<h3>Herramientas</h3>
						<ul class="stack-list">
							{stack.tools.map((tech) => <li>{tech}</li>)}
						</ul>
					</div>
				</div>
			</section>

			<div class="divider"></div>

			<!-- Cómo trabajo -->
			<div class="page-section section-block">
			<p class="section-label">// Cómo trabajo</p>
			<div class="work-grid">
				{workCards.map((card) => (
					<div class="work-card">
						<p class="tag">{card.tag}</p>
						<h3>{card.title}</h3>
						<p>{card.desc}</p>
					</div>
				))}
			</div>
			</div>

			<div class="divider"></div>

			<!-- Objetivo -->
			<blockquote class="goal-quote">
				Mi objetivo es seguir creciendo como desarrollador, aportar valor en cada proyecto y
				rodearme de personas que me reten a mejorar. Cada línea de código me motiva a construir
				cosas cada vez más sólidas, útiles y profesionales.
			</blockquote>
		</main>
		<Footer />
	</body>
</html>
