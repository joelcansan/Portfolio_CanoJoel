---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { titulo } from '../components/BaseHead.astro';

/**
 * Stack técnico organizado por categoría.
 * Cada tech tiene: name, icon (Devicon CDN), color (color de la marca).
 * Se usa el mismo formato de cards que en la Home.
 */
const stack = {
	frontend: [
		{ name: 'JavaScript', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg', color: '#F7DF1E' },
		{ name: 'TypeScript', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg', color: '#3178C6' },
		{ name: 'React', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg', color: '#61DAFB' },
		{ name: 'Next.js', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nextjs/nextjs-original.svg', color: '#ffffff' },
		{ name: 'Astro', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg', color: '#FF5D01' },
		{ name: 'HTML', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg', color: '#E34F26' },
		{ name: 'CSS', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/css3/css3-original.svg', color: '#1572B6' },
		{ name: 'Tailwind', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg', color: '#06B6D4' },
	],
	backend: [
		{ name: 'Node.js', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg', color: '#339933' },
		{ name: 'Express', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/express/express-original.svg', color: '#ffffff' },
		{ name: 'PHP', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/php/php-original.svg', color: '#777BB4' },
		{ name: 'Laravel', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/laravel/laravel-original.svg', color: '#FF2D20' },
	],
	database: [
		{ name: 'MySQL', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg', color: '#4479A1' },
		{ name: 'MariaDB', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mariadb/mariadb-original.svg', color: '#003545' },
		{ name: 'MongoDB', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mongodb/mongodb-original.svg', color: '#47A248' },
		{ name: 'Supabase', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/supabase/supabase-original.svg', color: '#3ECF8E' },
	],
	tools: [
		{ name: 'Git', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg', color: '#F05032' },
		{ name: 'Docker', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg', color: '#2496ED' },
		{ name: 'WordPress', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/wordpress/wordpress-plain.svg', color: '#21759B' },
	],
};

const profile = {
	nombre: 'Joel Cano Sánchez',
	rol: 'Full-stack junior',
	edad: 19,
	estudios: '2º DAW',
	experiencia: ['e-Corp Sistemas', 'Reactivació Badalona'],
	disponible: true,
};

const profileEn = {
	name: 'Joel Cano Sánchez',
	role: 'Full-stack junior',
	age: 19,
	studies: '2nd year DAW',
	experience: ['e-Corp Sistemas', 'Reactivació Badalona'],
	available: true,
};

function renderJson(keys: string[], values: Record<string, unknown>) {
	const experienceKey = keys.find(k => k === 'experiencia' || k === 'experience')!;
	const exp = values[experienceKey] as string[];
	const expLines = exp
		.map((e, i) => `    <span class="str">"${e}"</span>${i < exp.length - 1 ? ',' : ''}`)
		.join('\n');

	return `<span class="brace">{</span>
${keys.map(k => {
		const v = values[k];
		if (k === experienceKey) {
			return `  <span class="key">"${k}"</span>: [\n${expLines}\n  ]`;
		}
		if (typeof v === 'string') return `  <span class="key">"${k}"</span>: <span class="str">"${v}"</span>`;
		if (typeof v === 'number') return `  <span class="key">"${k}"</span>: <span class="num">${v}</span>`;
		if (typeof v === 'boolean') return `  <span class="key">"${k}"</span>: <span class="bool">${v}</span>`;
		return '';
	}).join(',\n')}
<span class="brace">}</span>`;
}

const jsonEs = renderJson(
	['nombre', 'rol', 'edad', 'estudios', 'experiencia', 'disponible'],
	{ nombre: profile.nombre, rol: profile.rol, edad: profile.edad, estudios: profile.estudios, experiencia: profile.experiencia, disponible: profile.disponible }
);

const jsonEn = renderJson(
	['name', 'role', 'age', 'studies', 'experience', 'available'],
	{ name: profileEn.name, role: profileEn.role, age: profileEn.age, studies: profileEn.studies, experience: profileEn.experience, available: profileEn.available }
);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`About | ${titulo}`} description="Sobre mí: educación, experiencia y stack como desarrollador full-stack junior." />
		<style>
			/* ── Hero ── */
			.about-hero { padding: 1rem 0 0.5rem; }
			.hero-content { display: flex; align-items: center; gap: 3em; }
			.hero-photo { flex: 0 0 220px; }
			.hero-photo img { width: 220px; height: 220px; object-fit: cover; border-radius: 12px; border: 2px solid var(--border); box-shadow: var(--shadow-glow); background: var(--bg-card); }
			.hero-text { flex: 1; }
			.greeting { font-family: var(--font-mono); font-size: 0.9em; color: var(--accent); margin-bottom: 0.75em; letter-spacing: 0.05em; }
			.about-hero h1 { font-size: 2.6em; margin-bottom: 0.45em; line-height: 1.15; }
			.hero-sub { color: var(--text-secondary); font-size: 1.05em; max-width: 520px; margin-bottom: 2em; line-height: 1.8; }
			.cta-links { display: flex; gap: 0.8em; flex-wrap: wrap; }
			.btn { display: inline-flex; align-items: center; gap: 0.4em; padding: 0.55em 1.1em; border-radius: 6px; font-family: var(--font-mono); font-size: 0.85em; text-decoration: none; transition: all 0.2s; }
			.btn-primary { background: var(--accent); color: #0a0e0f; border: 1px solid var(--accent); font-weight: 600; }
			.btn-primary:hover { background: var(--accent-dim); border-color: var(--accent-dim); box-shadow: var(--shadow-glow); text-shadow: none; color: #0a0e0f; }
			.btn-outline { background: transparent; color: var(--text-secondary); border: 1px solid var(--border); }
			.btn-outline:hover { color: var(--accent); border-color: var(--border-hover); background: var(--accent-glow); text-shadow: none; }
			.divider { height: 1px; background: var(--border); margin: var(--section-gap) 0; }

			/* ── Stats ── */
			.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25em; }
			.stat-card { padding: 1.2em 1.4em; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; transition: all 0.2s; }
			.stat-card:hover { border-color: var(--border-hover); box-shadow: var(--shadow-glow); transform: translateY(-2px); }
			.stat-value { font-family: var(--font-mono); font-size: 1.5em; font-weight: 700; color: var(--accent); margin-bottom: 0.2em; }
			.stat-label { font-family: var(--font-mono); font-size: 0.75em; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }

			/* ── Two columns: timeline + terminal ── */
			.content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
			.section-block .section-label { margin-bottom: 1.35rem; }

			/* Timeline */
			.timeline { list-style: none; padding: 0; margin: 0; position: relative; }
			.timeline::before {
				content: '';
				position: absolute;
				left: 7px; top: 8px; bottom: 8px;
				width: 2px;
				background: linear-gradient(
					to bottom,
					transparent 0%,
					var(--sig) 8%,
					var(--sig) 92%,
					transparent 100%
				);
				opacity: 0.55;
				box-shadow: 0 0 8px 1px rgba(0, 232, 122, 0.35);
			}
			.timeline li { position: relative; padding-left: 2em; padding-bottom: 1.75em; }
			.timeline li:last-child { padding-bottom: 0; }

			/* Círculo-botón */
			.timeline-dot {
				position: absolute;
				left: 0; top: 6px;
				width: 16px; height: 16px;
				border-radius: 50%;
				background: var(--bg-base);
				border: 2px solid var(--sig);
				box-shadow:
					0 0 0 3px rgba(0, 232, 122, 0.12),
					0 0 12px 3px rgba(0, 232, 122, 0.45),
					0 0 24px 4px rgba(0, 232, 122, 0.2);
				display: block;
				text-decoration: none;
				cursor: pointer;
				transition:
					background 0.45s ease,
					box-shadow 0.45s ease;
				z-index: 2;
				overflow: hidden;
			}

			/* Relleno que crece desde el centro */
			.timeline-dot::after {
				content: '';
				position: absolute;
				inset: 0;
				border-radius: 50%;
				background: var(--sig);
				transform: scale(0);
				transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
			}

			.timeline-dot:hover::after,
			.timeline-dot:focus-visible::after {
				transform: scale(1);
			}

			.timeline-dot:hover,
			.timeline-dot:focus-visible {
				box-shadow:
					0 0 0 4px rgba(0, 232, 122, 0.2),
					0 0 18px 5px rgba(0, 232, 122, 0.65),
					0 0 36px 8px rgba(0, 232, 122, 0.3);
				outline: none;
			}
			.timeline-period { font-family: var(--font-mono); font-size: 0.72em; color: var(--accent); letter-spacing: 0.05em; margin-bottom: 0.3em; }
			.timeline-title { font-family: var(--font-mono); font-size: 1em; font-weight: 600; color: var(--text-primary); margin: 0 0 0.15em; }
			.timeline-subtitle { font-size: 0.85em; color: var(--text-muted); margin: 0 0 0.4em; }
			.timeline-desc { font-size: 0.9em; color: var(--text-secondary); margin: 0; line-height: 1.6; }

			/* Terminal */
			.terminal-card { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
			.terminal-header { display: flex; align-items: center; gap: 6px; padding: 0.7em 1em; background: var(--bg-card); border-bottom: 1px solid var(--border); }
			.terminal-dot { width: 10px; height: 10px; border-radius: 50%; }
			.terminal-dot.red { background: #ff5f57; }
			.terminal-dot.yellow { background: #febc2e; }
			.terminal-dot.green { background: #28c840; }
			.terminal-filename { margin-left: 0.5em; font-family: var(--font-mono); font-size: 0.75em; color: var(--text-muted); }
			.terminal-body { padding: 1.2em 1.4em; font-family: var(--font-mono); font-size: 0.82em; line-height: 1.8; color: var(--text-secondary); }
			.terminal-body .brace { color: var(--text-primary); }
			.terminal-body .key { color: var(--accent); }
			.terminal-body .str { color: #7dd3a8; }
			.terminal-body .num { color: #f0ab6b; }
			.terminal-body .bool { color: #79b8ff; }

			/* ══════════════════════════════════════════════
			   Stack Cards — same style as Home
			   ══════════════════════════════════════════════ */
			.stack-section { margin-top: 0; }
			.stack-groups { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25em; }
			.stack-group { padding: 1.2em 1.4em; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; }
			.stack-group h3 { font-size: 0.8em; color: var(--accent); margin-bottom: 0.8em; letter-spacing: 0.06em; text-transform: uppercase; }
			.stack-group h3::before { content: none; }

			.stack-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 0.6em; list-style: none; padding: 0; margin: 0; }

			.stack-card {
				position: relative;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 0.5em;
				padding: 0.9em 0.5em 0.7em;
				background: var(--bg-elevated);
				border: 1px solid var(--border);
				border-radius: 8px;
				cursor: default;
				overflow: hidden;
				transition:
					transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
					border-color 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
					box-shadow 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
			}

			.stack-card::before {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0;
				height: 2px;
				background: var(--stack-color, var(--accent));
				opacity: 0;
				transition: opacity 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
			}

			.stack-card::after {
				content: '';
				position: absolute;
				top: -30%; left: 50%;
				transform: translateX(-50%);
				width: 120%; height: 100%;
				background: radial-gradient(ellipse at center top, var(--stack-glow, rgba(0,255,136,0.07)) 0%, transparent 70%);
				opacity: 0;
				transition: opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
				pointer-events: none;
				z-index: 0;
			}

			.stack-card:hover {
				transform: translateY(-4px);
				border-color: var(--border-hover);
				box-shadow: 0 6px 20px rgba(0,0,0,0.4), 0 0 14px var(--stack-glow, rgba(0,255,136,0.1));
			}
			.stack-card:hover::before { opacity: 1; }
			.stack-card:hover::after { opacity: 1; }

			.stack-icon {
				position: relative; z-index: 1;
				width: 30px; height: 30px;
				object-fit: contain;
				border: none; border-radius: 0;
				filter: grayscale(0.4) brightness(0.85);
				transition: transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94), filter 0.45s cubic-bezier(0.25,0.46,0.45,0.94);
			}
			.stack-card:hover .stack-icon {
				transform: scale(1.15);
				filter: grayscale(0) brightness(1.15) drop-shadow(0 0 8px var(--stack-glow, rgba(0,255,136,0.3)));
			}

			.stack-name {
				position: relative; z-index: 1;
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				white-space: nowrap;
				transition: color 0.45s cubic-bezier(0.25,0.46,0.45,0.94);
			}
			.stack-card:hover .stack-name { color: var(--text-primary); }

			/* ── Work cards ── */
			.work-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25em; }
			.work-card { padding: 1.3em 1.4em; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; transition: all 0.2s; }
			.work-card:hover { border-color: var(--border-hover); box-shadow: var(--shadow-glow); transform: translateY(-2px); }
			.work-card .tag { font-family: var(--font-mono); font-size: 0.7em; color: var(--accent); margin-bottom: 0.5em; }
			.work-card h3 { font-size: 1em; margin-bottom: 0.4em; }
			.work-card h3::before { content: none; }
			.work-card p { margin: 0; font-size: 0.88em; line-height: 1.6; }

			/* ── Quote ── */
			.goal-quote { margin: 0; font-size: 1.05em; line-height: 1.75; }

			/* ── Bilingüe: mostrar/ocultar por idioma ── */
			.lang-en, .lang-es { display: none !important; }
			html[data-active-lang="es"] .lang-es { display: block !important; }
			html[data-active-lang="en"] .lang-en { display: block !important; }
			html:not([data-active-lang]) .lang-es { display: block !important; }

			/* ── Responsive ── */
			@media (max-width: 768px) {
				.hero-content { flex-direction: column; text-align: center; gap: 2em; }
				.hero-sub { max-width: none; }
				.cta-links { justify-content: center; }
				.hero-photo img { width: 200px; height: 200px; }
				.stats-grid { grid-template-columns: repeat(2, 1fr); }
				.content-grid { grid-template-columns: 1fr; gap: 2.5rem; }
				.stack-groups { grid-template-columns: 1fr; }
				.work-grid { grid-template-columns: 1fr; }
				.about-hero h1 { font-size: 2.2em; }
			}
			@media (max-width: 480px) {
				.stats-grid { grid-template-columns: 1fr; }
				.about-hero h1 { font-size: 1.9em; }
				.hero-photo img { width: 180px; height: 180px; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<!-- Hero -->
			<section class="about-hero">
				<div class="hero-content">
					<div class="hero-photo reveal-up">
						<img src="/images/joelcano.png" alt="Foto de perfil de Joel Cano Sánchez" width="220" height="220" />
					</div>
					<div class="hero-text">
						<p class="greeting reveal-fade" data-i18n="about.greeting">// sobre_mí</p>
						<h1 class="reveal-up reveal-delay-1" data-i18n="about.name">Joel Cano Sánchez</h1>
						<p class="hero-sub reveal-up reveal-delay-2" data-i18n="about.sub">
							Desarrollador full-stack junior con 19 años. Me apasiona crear aplicaciones desde cero, resolver problemas reales y ver cómo una idea se convierte en algo funcional.
						</p>
						<div class="cta-links reveal-up reveal-delay-3">
							<a href="/projects" class="btn btn-primary" data-i18n="about.cta.projects">Ver proyectos →</a>
							<a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer" class="btn btn-outline" data-i18n="about.cta.github" aria-label="GitHub (abre en nueva pestaña)">GitHub</a>
							<a href="mailto:joelcanosan@gmail.com" class="btn btn-outline" data-i18n="about.cta.contact">Contacto</a>
						</div>
					</div>
				</div>
			</section>

			<div class="divider"></div>

			<!-- Stats -->
			<div class="stats-grid page-section" role="list" aria-label="Datos rápidos">
				<div class="stat-card reveal-up reveal-delay-1" role="listitem">
					<div class="stat-value" data-i18n="about.stat.age">19</div>
					<div class="stat-label" data-i18n="about.stat.ageLabel">Años</div>
				</div>
				<div class="stat-card reveal-up reveal-delay-2" role="listitem">
					<div class="stat-value" data-i18n="about.stat.course">2º</div>
					<div class="stat-label" data-i18n="about.stat.courseLabel">DAW</div>
				</div>
				<div class="stat-card reveal-up reveal-delay-3" role="listitem">
					<div class="stat-value" data-i18n="about.stat.role">Full-stack</div>
					<div class="stat-label" data-i18n="about.stat.roleLabel">Junior</div>
				</div>
				<div class="stat-card reveal-up reveal-delay-4" role="listitem">
					<div class="stat-value" data-i18n="about.stat.intern">2</div>
					<div class="stat-label" data-i18n="about.stat.internLabel">Prácticas</div>
				</div>
			</div>

			<div class="divider"></div>

			<!-- Timeline + Terminal -->
			<div class="content-grid page-section">
				<div>
					<p class="section-label reveal-left" data-i18n="about.section.timeline">// Mi camino</p>
					<ul class="timeline">
						<li class="reveal-up reveal-delay-1">
							<a href="https://www.fpllefia.com/" target="_blank" rel="noopener noreferrer" class="timeline-dot" aria-label="Web del instituto FP Llefia (abre en nueva pestaña)"></a>
							<p class="timeline-period" data-i18n="about.t1.period">2022 — 2024</p>
							<h3 class="timeline-title" data-i18n="about.t1.title">SMR</h3>
							<p class="timeline-subtitle" data-i18n="about.t1.sub">Sistemas Microinformáticos y Redes</p>
							<p class="timeline-desc" data-i18n="about.t1.desc">Base sólida en hardware, redes y sistemas operativos.</p>
						</li>
						<li class="reveal-up reveal-delay-2">
							<a href="https://www.fpllefia.com/" target="_blank" rel="noopener noreferrer" class="timeline-dot" aria-label="Web del instituto FP Llefia (abre en nueva pestaña)"></a>
							<p class="timeline-period" data-i18n="about.t2.period">2024 — Actualidad</p>
							<h3 class="timeline-title" data-i18n="about.t2.title">DAW</h3>
							<p class="timeline-subtitle" data-i18n="about.t2.sub">Desarrollo de Aplicaciones Web</p>
							<p class="timeline-desc" data-i18n="about.t2.desc">Segundo curso. Full-stack, APIs, bases de datos y despliegue.</p>
						</li>
						<li class="reveal-up reveal-delay-3">
							<a href="https://www.e-corp.es/" target="_blank" rel="noopener noreferrer" class="timeline-dot" aria-label="Web de e-Corp Sistemas (abre en nueva pestaña)"></a>
							<p class="timeline-period" data-i18n="about.t3.period">Prácticas</p>
							<h3 class="timeline-title" data-i18n="about.t3.title">e-Corp Sistemas</h3>
							<p class="timeline-subtitle" data-i18n="about.t3.sub">Montaje y sistemas</p>
							<p class="timeline-desc" data-i18n="about.t3.desc">Montaje de ordenadores, instalación y configuración de sistemas operativos.</p>
						</li>
						<li class="reveal-up reveal-delay-4">
							<a href="https://reactivaciobadalona.cat/" target="_blank" rel="noopener noreferrer" class="timeline-dot" aria-label="Web de Reactivació Badalona (abre en nueva pestaña)"></a>
