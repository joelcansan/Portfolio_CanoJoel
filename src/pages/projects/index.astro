---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { titulo } from '../../components/BaseHead.astro';

const projects = (await getCollection('project')).sort((a, b) => {
  const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
  const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
  return dateB - dateA;
});
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title={`Proyectos | ${titulo}`} description={SITE_DESCRIPTION} />
  <style>
    main { padding-top: 6rem; }

    /* ════════════════════════════════════════
       CABECERA
       ════════════════════════════════════════ */
    .page-header {
      margin-bottom: 3rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--line);
    }

    .page-header h1 { font-size: 2.6rem; margin-bottom: 0.2rem; }

    .page-sub {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--ink-2);
      letter-spacing: 0.1em;
      margin: 0;
    }

    /* ════════════════════════════════════════
       GRID DE PROYECTOS — FULL IMAGEN
       ════════════════════════════════════════ */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
      list-style: none;
    }

    /* Primer proyecto: ocupa las dos columnas */
    .proj-item:first-child {
      grid-column: 1 / -1;
    }

    /* ── Tarjeta ── */
    .proj-card {
      position: relative;
      display: block;
      border-radius: var(--r-lg);
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      /* Altura según posición */
      height: 480px;
      opacity: 0;
      transform: translateY(40px);
      transition:
        opacity 0.7s cubic-bezier(0.22,1,0.36,1),
        transform 0.7s cubic-bezier(0.22,1,0.36,1),
        box-shadow 0.35s ease;
    }

    .proj-item:first-child .proj-card {
      height: 560px;
    }

    .proj-card.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* Retrasos escalonados */
    .proj-item:nth-child(1) .proj-card { transition-delay: 0.04s; }
    .proj-item:nth-child(2) .proj-card { transition-delay: 0.10s; }
    .proj-item:nth-child(3) .proj-card { transition-delay: 0.16s; }
    .proj-item:nth-child(4) .proj-card { transition-delay: 0.06s; }
    .proj-item:nth-child(5) .proj-card { transition-delay: 0.12s; }
    .proj-item:nth-child(n+6) .proj-card { transition-delay: 0.06s; }

    .proj-card:hover {
      box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 0 0 1px var(--line-hot);
    }

    /* Imagen — fondo completo */
    .proj-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 0;
      border: none;
      display: block;
      transition: transform 0.6s cubic-bezier(0.22,1,0.36,1), filter 0.4s;
      filter: brightness(0.5) saturate(0.9);
    }

    .proj-card:hover .proj-img {
      transform: scale(1.04);
      filter: brightness(0.4) saturate(0.8);
    }

    /* Placeholder sin imagen */
    .proj-placeholder {
      position: absolute;
      inset: 0;
      background: var(--surface-2);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--ink-3);
    }

    /* Overlay degradado */
    .proj-overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(
          160deg,
          rgba(7,9,11,0.2) 0%,
          rgba(7,9,11,0.65) 60%,
          rgba(7,9,11,0.95) 100%
        );
      transition: background 0.4s;
    }

    .proj-card:hover .proj-overlay {
      background:
        linear-gradient(
          160deg,
          rgba(7,9,11,0.3) 0%,
          rgba(7,9,11,0.75) 60%,
          rgba(7,9,11,0.98) 100%
        );
    }

    /* Contenido superpuesto */
    .proj-content {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2rem 2rem 2rem;
      z-index: 2;
    }

    .proj-item:first-child .proj-content {
      padding: 2.5rem;
    }

    /* Número */
    .proj-num {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--sig);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
      opacity: 0.8;
    }

    /* Título */
    .proj-title {
      font-family: var(--mono);
      font-weight: 800;
      color: #fff;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
      font-size: 1.4rem;
      text-shadow: 0 2px 16px rgba(0,0,0,0.5);
    }

    .proj-item:first-child .proj-title {
      font-size: clamp(1.6rem, 3vw, 2.2rem);
    }

    .proj-title::before { content: none !important; }

    /* Descripción — solo visible en hover */
    .proj-desc {
      color: rgba(255,255,255,0.65);
      font-size: 0.84rem;
      line-height: 1.6;
      margin-bottom: 1rem;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 0.4s cubic-bezier(0.22,1,0.36,1), opacity 0.35s ease;
    }

    .proj-card:hover .proj-desc {
      max-height: 5em;
      opacity: 1;
    }

    /* Chips de tecnologías */
    .proj-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35em;
      margin-bottom: 1rem;
    }

    .proj-chip {
      padding: 0.2em 0.6em;
      background: rgba(0,232,122,0.1);
      border: 1px solid rgba(0,232,122,0.22);
      border-radius: 100px;
      font-family: var(--mono);
      font-size: 0.66rem;
      color: var(--sig);
      letter-spacing: 0.04em;
      backdrop-filter: blur(6px);
    }

    /* Flecha "ver" — aparece al hover */
    .proj-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.4em;
      font-family: var(--mono);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--sig);
      opacity: 0;
      transform: translateX(-8px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .proj-card:hover .proj-arrow {
      opacity: 1;
      transform: translateX(0);
    }

    /* ── Índice grande — marca de agua ── */
    .proj-watermark {
      position: absolute;
      top: 1rem;
      right: 1.25rem;
      font-family: var(--mono);
      font-size: 5rem;
      font-weight: 900;
      color: rgba(255,255,255,0.04);
      line-height: 1;
      pointer-events: none;
      user-select: none;
      z-index: 1;
      transition: color 0.4s;
    }

    .proj-card:hover .proj-watermark {
      color: rgba(0,232,122,0.06);
    }

    /* ── Estado vacío ── */
    .empty {
      text-align: center;
      padding: 5em 2em;
      background: var(--surface-1);
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
      font-family: var(--mono);
      font-size: 0.88rem;
      color: var(--ink-2);
    }

    /* ════════════════════════════════════════
       RESPONSIVE
       ════════════════════════════════════════ */
    @media (max-width: 720px) {
      .projects-grid { grid-template-columns: 1fr; }
      .proj-item:first-child { grid-column: auto; }
      .proj-card,
      .proj-item:first-child .proj-card { height: 360px; }
      .proj-title { font-size: 1.2rem; }
      .proj-item:first-child .proj-title { font-size: 1.4rem; }
      .proj-desc { max-height: 4em; opacity: 0.8; } /* En móvil siempre visible */
      .proj-arrow { opacity: 1; transform: none; }
    }

    @media (max-width: 480px) {
      .page-header h1 { font-size: 2rem; }
      .proj-card,
      .proj-item:first-child .proj-card { height: 300px; }
    }
  </style>
</head>
<body>
  <Header />
  <main>

    <div class="page-header reveal-up" data-reveal>
      <h1>Proyectos</h1>
      <p class="page-sub">
        // {projects.length} proyecto{projects.length !== 1 ? 's' : ''} en total
      </p>
    </div>

    {projects.length === 0 ? (
      <div class="empty">// No hay proyectos todavía. ¡Pronto!</div>
    ) : (
      <ul class="projects-grid">
        {projects.map((project, i) => (
          <li class="proj-item" data-proj-item>
            <a
              href={`/projects/${project.id}/`}
              class="proj-card"
              data-index={String(i + 1).padStart(2, '0')}
            >
              {/* Imagen full */}
              {project.data.heroImage ? (
                <Image
                  class="proj-img"
                  width={i === 0 ? 1400 : 900}
                  height={i === 0 ? 700 : 560}
                  src={project.data.heroImage}
                  alt={project.data.name}
                />
              ) : (
                <div class="proj-placeholder">
                  <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <path d="M8 21h8M12 17v4"/>
                  </svg>
                </div>
              )}

              {/* Overlay */}
              <div class="proj-overlay"></div>

              {/* Watermark número */}
              <span class="proj-watermark">{String(i + 1).padStart(2, '0')}</span>

              {/* Contenido */}
              <div class="proj-content">
                <p class="proj-num">
                  {String(i + 1).padStart(2, '0')} / {String(projects.length).padStart(2, '0')}
                </p>
                <h2 class="proj-title">{project.data.name}</h2>
                <p class="proj-desc">{project.data.description}</p>

                {project.data.techs && project.data.techs.length > 0 && (
                  <div class="proj-chips">
                    {project.data.techs.map(t => <span class="proj-chip">{t}</span>)}
                  </div>
                )}

                <span class="proj-arrow">
                  Ver proyecto
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}

  </main>
  <Footer />

  <script is:inline>
    (function () {
      /* Reveal genérico */
      var revEls = document.querySelectorAll('[data-reveal]');
      var projItems = document.querySelectorAll('[data-proj-item] .proj-card');

      function makeObserver(els, threshold) {
        if (!('IntersectionObserver' in window)) {
          els.forEach(function (el) { el.classList.add('revealed'); });
          return;
        }
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('revealed');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: threshold, rootMargin: '0px 0px -40px 0px' });
        els.forEach(function (el) { obs.observe(el); });
      }

      makeObserver(revEls, 0.1);
      makeObserver(projItems, 0.08);
    })();
  </script>
</body>
</html>
