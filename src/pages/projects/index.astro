---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import {SITE_DESCRIPTION} from '../../consts';
import { titulo } from '../../components/BaseHead.astro';


const projects = (await getCollection('project')).sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
	return dateB - dateA;
});
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Proyectos | ${titulo}`} description={SITE_DESCRIPTION} />
		<style>

			.page-header {
				margin-bottom: 3em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid var(--border);
			}

			.page-header h1 {
				margin-bottom: 0.2em;
				font-size: 2.4em;
			}

			.page-header .subtitle {
				color: var(--text-muted);
				font-family: var(--font-mono);
				font-size: 0.85em;
				margin: 0;
			}

			/* Grid estilo blog */
			.projects-list {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			/* Card destacada (primera) */
			.project-card-featured {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 12px;
				overflow: hidden;
				text-decoration: none;
				color: inherit;
				transition: all 0.25s ease;
				position: relative;
			}

			.project-card-featured::before {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--accent), transparent);
				opacity: 0;
				transition: opacity 0.25s;
			}

			.project-card-featured:hover {
				border-color: var(--border-hover);
				box-shadow: var(--shadow-glow);
				transform: translateY(-2px);
				text-shadow: none;
			}

			.project-card-featured:hover::before {
				opacity: 1;
			}

			.featured-image {
				width: 100%;
				height: 280px;
				object-fit: cover;
				border-radius: 0;
				border: none;
				display: block;
			}

			.featured-placeholder {
				width: 100%;
				height: 280px;
				background: var(--bg-elevated);
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.featured-placeholder svg {
				color: var(--border-hover);
			}

			.featured-body {
				padding: 2em;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.featured-tag {
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--accent);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 0.8em;
			}

			.featured-body h2 {
				font-size: 1.5em;
				margin-bottom: 0.6em;
				color: var(--text-primary);
				line-height: 1.2;
			}

			.featured-body h2::before {
				content: none;
			}

			.featured-desc {
				color: var(--text-secondary);
				font-size: 0.92em;
				line-height: 1.7;
				margin-bottom: 1.2em;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.featured-techs {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
			}

			.tech-chip {
				padding: 0.2em 0.6em;
				background: var(--bg-base);
				border: 1px solid var(--border);
				border-radius: 4px;
				font-family: var(--font-mono);
				font-size: 0.75em;
				color: var(--accent);
			}

			/* Cards normales */
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.2rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.project-card {
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
				overflow: hidden;
				text-decoration: none;
				color: inherit;
				transition: all 0.25s ease;
				display: flex;
				flex-direction: column;
				position: relative;
			}

			.project-card::before {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--accent), transparent);
				opacity: 0;
				transition: opacity 0.25s;
			}

			.project-card:hover {
				border-color: var(--border-hover);
				box-shadow: var(--shadow-glow);
				transform: translateY(-3px);
				text-shadow: none;
			}

			.project-card:hover::before {
				opacity: 1;
			}

			.card-img {
				width: 100%;
				height: 180px;
				object-fit: cover;
				border-radius: 0;
				border: none;
				display: block;
			}

			.card-img-placeholder {
				width: 100%;
				height: 180px;
				background: var(--bg-elevated);
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.card-body {
				padding: 1.2em 1.4em 1.4em;
				flex: 1;
				display: flex;
				flex-direction: column;
			}

			.card-tag {
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--accent);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 0.5em;
			}

			.card-title {
				margin: 0 0 0.5em 0;
				color: var(--text-primary);
				font-family: var(--font-mono);
				font-size: 1em;
				font-weight: 600;
				line-height: 1.3;
			}

			.card-title::before {
				content: none !important;
			}

			.card-desc {
				margin: 0 0 1em;
				color: var(--text-muted);
				font-size: 0.87em;
				line-height: 1.6;
				flex: 1;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.card-techs {
				display: flex;
				flex-wrap: wrap;
				gap: 0.3em;
			}

			/* Empty */
			.empty-state {
				text-align: center;
				padding: 4em 2em;
				color: var(--text-muted);
				font-family: var(--font-mono);
			}

			@media (max-width: 768px) {
				.page-header h1 {
					font-size: 2em;
				}

				.project-card-featured {
					grid-template-columns: 1fr;
				}

				.featured-image,
				.featured-placeholder {
					height: 200px;
				}

				.featured-body {
					padding: 1.5em;
				}

				.projects-grid {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 480px) {
				.page-header {
					margin-bottom: 2em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Proyectos</h1>
				<p class="subtitle">// {projects.length} proyecto{projects.length !== 1 ? 's' : ''} en total</p>
			</div>

			{projects.length === 0 ? (
				<div class="empty-state">
					<p>// No hay proyectos todavía. ¡Pronto!</p>
				</div>
			) : (
				<ul class="projects-list">
					{/* Primera card destacada */}
					{projects[0] && (
						<li>
							<a href={`/projects/${projects[0].id}/`} class="project-card-featured">
								{projects[0].data.heroImage ? (
									<Image
										class="featured-image"
										width={600}
										height={280}
										src={projects[0].data.heroImage}
										alt={projects[0].data.name}
									/>
								) : (
									<div class="featured-placeholder">
										<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
											<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
										</svg>
									</div>
								)}
								<div class="featured-body">
									<p class="featured-tag">// Proyecto destacado</p>
									<h2>{projects[0].data.name}</h2>
									<p class="featured-desc">{projects[0].data.description}</p>
									{projects[0].data.techs && projects[0].data.techs.length > 0 && (
										<div class="featured-techs">
											{projects[0].data.techs.map((tech) => (
												<span class="tech-chip">{tech}</span>
											))}
										</div>
									)}
								</div>
							</a>
						</li>
					)}

					{/* Resto de cards en grid */}
					{projects.length > 1 && (
						<li>
							<ul class="projects-grid">
								{projects.slice(1).map((project) => (
									<li>
										<a href={`/projects/${project.id}/`} class="project-card">
											{project.data.heroImage ? (
												<Image
													class="card-img"
													width={400}
													height={180}
													src={project.data.heroImage}
													alt={project.data.name}
												/>
											) : (
												<div class="card-img-placeholder">
													<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
														<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
													</svg>
												</div>
											)}
											<div class="card-body">
												<p class="card-tag">// proyecto</p>
												<h3 class="card-title">{project.data.name}</h3>
												<p class="card-desc">{project.data.description}</p>
												{project.data.techs && project.data.techs.length > 0 && (
													<div class="card-techs">
														{project.data.techs.slice(0, 3).map((tech) => (
															<span class="tech-chip">{tech}</span>
														))}
														{project.data.techs.length > 3 && (
															<span class="tech-chip">+{project.data.techs.length - 3}</span>
														)}
													</div>
												)}
											</div>
										</a>
									</li>
								))}
							</ul>
						</li>
					)}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
