---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';
import { titulo } from '../components/BaseHead.astro';

const projects = (await getCollection('project')).sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
	return dateB - dateA;
});

const latestProjects = projects.slice(0, 4);

// Paletas de color por proyecto cuando no hay imagen
const fallbackColors = [
  { from: '#0f2027', to: '#203a43' },
  { from: '#1a0533', to: '#2d1b69' },
  { from: '#0d1f0f', to: '#1a3a1e' },
  { from: '#1f0d0d', to: '#3a1a1a' },
];

const stackMini = [
	{ name: 'React',       icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg',       color: '#61DAFB' },
	{ name: 'Next.js',    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nextjs/nextjs-original.svg',     color: '#ffffff' },
	{ name: 'Node.js',    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg',     color: '#339933' },
	{ name: 'JavaScript', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg', color: '#F7DF1E' },
	{ name: 'PHP',        icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/php/php-original.svg',           color: '#777BB4' },
	{ name: 'Laravel',    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/laravel/laravel-original.svg',   color: '#FF2D20' },
	{ name: 'MySQL',      icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg',       color: '#4479A1' },
	{ name: 'Astro',      icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg',       color: '#FF5D01' },
	{ name: 'Git',        icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg',           color: '#F05032' },
	{ name: 'Docker',     icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg',     color: '#2496ED' },
];
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title={`Home | ${titulo}`} description={SITE_DESCRIPTION} />
  <style>
    /* El main tiene padding-top para el header fijo */
    main { padding-top: 4rem; padding-bottom: 3rem; }

    /* ════════════════════════════════════════
       HERO
       ════════════════════════════════════════ */
    .hero {
      min-height: 60vh;
      display: flex;
      align-items: center;
      margin-bottom: calc(var(--gap) * 0.6);
      padding: 3.5rem 0 2rem;
    }

    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 270px;
      align-items: center;
      gap: 2.5rem;
      width: 100%;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5em;
      padding: 0.28em 0.85em;
      background: var(--sig-faint);
      border: 1px solid rgba(0,232,122,0.2);
      border-radius: 100px;
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--sig);
      letter-spacing: 0.08em;
      margin-bottom: 1.75rem;
      width: fit-content;
    }

    .badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--sig);
      animation: dot-pulse 2.2s ease-in-out infinite;
    }

    @keyframes dot-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(0,232,122,0.5); }
      50%       { box-shadow: 0 0 0 6px rgba(0,232,122,0); }
    }

    /* ════════════════════════════════════════
       HERO TEXT TICKER — slide vertical independiente
       Nombre sale arriba, rol entra desde abajo,
       ambos en la misma posición fija.
       ════════════════════════════════════════ */
    .hero-ticker {
      position: relative;
      height: clamp(2.9rem, 6.6vw, 4.9rem);
      overflow: hidden;
      margin-bottom: 1.75rem;
    }

    .ticker-item {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
    }

    /* Estado inicial */
    #ticker-name { transform: translateY(0);    opacity: 1; }
    #ticker-role { transform: translateY(100%); opacity: 0; }

    /* Transiciones individuales */
    #ticker-name,
    #ticker-role {
      transition:
        transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1),
        opacity   0.4s ease;
    }

    /* Nombre saliendo hacia arriba */
    #ticker-name.exit  { transform: translateY(-110%); opacity: 0; }
    /* Rol entrando desde abajo con rebote */
    #ticker-role.enter { transform: translateY(0);     opacity: 1; }

    /* Rol saliendo hacia arriba (sin rebote, limpio) */
    #ticker-role.exit  {
      transform: translateY(-110%);
      opacity: 0;
      transition:
        transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
        opacity   0.3s ease;
    }
    /* Nombre volviendo desde abajo */
    #ticker-name.enter {
      transform: translateY(0);
      opacity: 1;
      transition:
        transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1),
        opacity   0.4s ease;
    }

    /* El prefijo > del h1 global no aplica aquí */
    .ticker-name::before,
    .ticker-role::before { content: none !important; }

    /* El nombre */
    .ticker-name {
      font-family: var(--mono);
      font-size: clamp(2.4rem, 5.5vw, 4rem);
      font-weight: 800;
      letter-spacing: -0.045em;
      color: var(--ink-0);
      white-space: nowrap;
      line-height: 1;
    }

    /* El rol */
    .ticker-role {
      font-family: var(--mono);
      font-size: clamp(1.6rem, 3.8vw, 2.8rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--sig);
      white-space: nowrap;
      line-height: 1;
    }

    .hero-desc {
      font-size: 1rem;
      color: var(--ink-1);
      line-height: 1.85;
      max-width: 46ch;
      margin-bottom: 2.5rem;
    }

    .hero-ctas { display: flex; gap: 0.6rem; flex-wrap: wrap; }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4em;
      padding: 0.62em 1.3em;
      border-radius: var(--r-sm);
      font-family: var(--mono);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.22s;
      white-space: nowrap;
    }

    .btn-primary { background: var(--sig); color: var(--void); border: 1px solid var(--sig); }
    .btn-primary:hover { background: var(--sig-dim); box-shadow: 0 0 24px rgba(0,232,122,0.28); opacity: 1; color: var(--void); }
    .btn-ghost { background: transparent; color: var(--ink-1); border: 1px solid var(--line); }
    .btn-ghost:hover { color: var(--ink-0); border-color: var(--line-mid); background: rgba(255,255,255,0.04); opacity: 1; }

    .hero-photo { display: flex; justify-content: center; }

    .photo-wrap {
      position: relative;
      width: 260px; height: 260px;
    }

    /* Esquinas bracket sin rotación */
    .photo-wrap::before { content: ''; position: absolute; top: -8px; left: -8px; width: 22px; height: 22px; border-top: 2px solid var(--sig); border-left: 2px solid var(--sig); opacity: 0.6; z-index: 2; }
    .photo-wrap::after  { content: ''; position: absolute; bottom: -8px; right: -8px; width: 22px; height: 22px; border-bottom: 2px solid var(--sig); border-right: 2px solid var(--sig); opacity: 0.6; z-index: 2; }

    .photo-inner { position: relative; width: 100%; height: 100%; }
    .photo-inner::before { content: ''; position: absolute; top: -8px; right: -8px; width: 22px; height: 22px; border-top: 2px solid var(--sig); border-right: 2px solid var(--sig); opacity: 0.6; z-index: 2; }
    .photo-inner::after  { content: ''; position: absolute; bottom: -8px; left: -8px; width: 22px; height: 22px; border-bottom: 2px solid var(--sig); border-left: 2px solid var(--sig); opacity: 0.6; z-index: 2; }

    .photo-wrap img {
      width: 100%; height: 100%;
      object-fit: cover;
      border-radius: var(--r-lg);
      border: 1px solid var(--line);
      display: block;
      position: relative; z-index: 1;
    }

    /* ════════════════════════════════════════
       DIVISOR
       ════════════════════════════════════════ */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--line-mid) 30%, var(--line-mid) 70%, transparent);
      margin: 0 0 var(--gap);
    }

    /* ════════════════════════════════════════
       SECTION HEAD
       ════════════════════════════════════════ */
    .section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
    }
    .section-head .section-label { margin-bottom: 0; }
    .link-all {
      font-family: var(--mono); font-size: 0.7rem; color: var(--ink-2);
      text-decoration: none; letter-spacing: 0.06em; transition: color 0.2s;
    }
    .link-all:hover { color: var(--sig); opacity: 1; }

    /* ════════════════════════════════════════
       PROYECTOS — Lista profesional
       Lo que quiere ver un reclutador:
       título claro, descripción, stack, links
       ════════════════════════════════════════ */
    .proj-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      list-style: none;
    }

    .proj-item {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.6s cubic-bezier(0.22,1,0.36,1), transform 0.6s cubic-bezier(0.22,1,0.36,1);
      border-bottom: 1px solid var(--line);
    }
    .proj-item:first-child { border-top: 1px solid var(--line); }
    .proj-item.revealed { opacity: 1; transform: translateY(0); }
    .proj-item:nth-child(1) { transition-delay: 0.05s; }
    .proj-item:nth-child(2) { transition-delay: 0.12s; }
    .proj-item:nth-child(3) { transition-delay: 0.19s; }
    .proj-item:nth-child(4) { transition-delay: 0.26s; }

    .proj-card {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 2rem;
      padding: 2rem 0;
      text-decoration: none;
      color: inherit;
      transition: background 0.2s;
      position: relative;
    }

    /* Línea verde que aparece a la izquierda al hover */
    .proj-card::before {
      content: '';
      position: absolute;
      left: -1.25rem;
      top: 50%;
      transform: translateY(-50%) scaleY(0);
      width: 3px;
      height: 60%;
      background: var(--sig);
      border-radius: 2px;
      transition: transform 0.25s cubic-bezier(0.22,1,0.36,1);
    }

    .proj-card:hover::before { transform: translateY(-50%) scaleY(1); }

    .proj-main { flex: 1; min-width: 0; }

    .proj-top {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 0.5rem;
      flex-wrap: wrap;
    }

    .proj-num {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--sig);
      letter-spacing: 0.14em;
      flex-shrink: 0;
      opacity: 0.7;
    }

    .proj-name {
      font-family: var(--mono);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--ink-0);
      letter-spacing: -0.02em;
      transition: color 0.2s;
      line-height: 1.2;
    }
    .proj-card:hover .proj-name { color: var(--sig); }
    .proj-name::before { content: none !important; }

    .proj-desc {
      color: var(--ink-1);
      font-size: 0.88rem;
      line-height: 1.7;
      margin: 0 0 0.85rem;
      max-width: 60ch;
    }

    .proj-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3em;
    }

    .proj-chip {
      padding: 0.18em 0.6em;
      background: var(--surface-2);
      border: 1px solid var(--line);
      border-radius: 3px;
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--sig);
      letter-spacing: 0.03em;
      transition: border-color 0.2s;
    }
    .proj-card:hover .proj-chip { border-color: var(--line-mid); }

    /* Derecha: flecha + año */
    .proj-aside {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.5rem;
      flex-shrink: 0;
    }

    .proj-year {
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--ink-3);
      letter-spacing: 0.06em;
    }

    .proj-arrow {
      width: 36px; height: 36px;
      border-radius: 50%;
      border: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--ink-2);
      transition: border-color 0.2s, background 0.2s, color 0.2s, transform 0.25s;
    }
    .proj-card:hover .proj-arrow {
      border-color: var(--sig);
      background: var(--sig-faint);
      color: var(--sig);
      transform: translate(3px, -3px);
    }

    /* Estado vacío */
    .empty-projects {
      padding: 3em; text-align: center;
      background: var(--surface-1); border: 1px solid var(--line);
      border-radius: var(--r-lg); font-family: var(--mono);
      font-size: 0.85rem; color: var(--ink-2);
    }

    /* Ver todos */
    .proj-footer {
      display: flex; align-items: center;
      justify-content: flex-end; padding-top: 1.25rem;
    }
    .proj-footer a {
      font-family: var(--mono); font-size: 0.75rem; color: var(--ink-2);
      text-decoration: none; letter-spacing: 0.08em;
      display: flex; align-items: center; gap: 0.4em; transition: color 0.2s;
    }
    .proj-footer a:hover { color: var(--sig); opacity: 1; }

    /* ════════════════════════════════════════
       POR QUÉ YO
       ════════════════════════════════════════ */
    .highlights {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin-bottom: 1.75rem;
    }

    .hl-item {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding: 0.95rem 1.2rem;
      background: var(--surface-1);
      border: 1px solid var(--line);
      border-radius: var(--r-md);
      color: var(--ink-1);
      font-size: 0.9rem;
      line-height: 1.75;
      transition: border-color 0.2s, background 0.2s, transform 0.2s;
    }
    .hl-item:hover { border-color: var(--line-mid); background: var(--surface-2); transform: translateX(4px); }
    .hl-arrow { font-family: var(--mono); color: var(--sig); flex-shrink: 0; padding-top: 0.1em; }

    .about-link {
      font-family: var(--mono); font-size: 0.78rem; color: var(--ink-2);
      text-decoration: none; display: inline-flex; align-items: center;
      gap: 0.3em; letter-spacing: 0.04em; transition: color 0.2s;
    }
    .about-link:hover { color: var(--sig); opacity: 1; }

    /* ════════════════════════════════════════
       STACK
       ════════════════════════════════════════ */
    .stack-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.7rem;
      list-style: none;
    }

    .stack-card {
      position: relative;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 0.6em;
      padding: 1.2em 0.75em 1em;
      background: var(--surface-1);
      border: 1px solid var(--line);
      border-radius: var(--r-md);
      overflow: hidden;
      cursor: default;
      transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94), border-color 0.4s, box-shadow 0.4s;
    }
    .stack-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--stack-color, var(--sig)); opacity: 0; transition: opacity 0.4s; }
    .stack-card::after  { content: ''; position: absolute; top: -40%; left: 50%; transform: translateX(-50%); width: 140%; height: 120%; background: radial-gradient(ellipse at center top, var(--stack-glow, rgba(0,232,122,0.08)) 0%, transparent 70%); opacity: 0; transition: opacity 0.5s; pointer-events: none; }
    .stack-card:hover { transform: translateY(-6px); border-color: rgba(255,255,255,0.1); box-shadow: 0 12px 36px rgba(0,0,0,0.5); }
    .stack-card:hover::before, .stack-card:hover::after { opacity: 1; }

    .stack-icon { width: 36px; height: 36px; object-fit: contain; border: none; border-radius: 0; position: relative; z-index: 1; filter: grayscale(0.45) brightness(0.78); transition: transform 0.4s, filter 0.4s; }
    .stack-card:hover .stack-icon { transform: scale(1.2); filter: grayscale(0) brightness(1.1) drop-shadow(0 0 8px var(--stack-glow, rgba(0,232,122,0.35))); }
    .stack-name { position: relative; z-index: 1; font-family: var(--mono); font-size: 0.7rem; color: var(--ink-2); white-space: nowrap; transition: color 0.4s; }
    .stack-card:hover .stack-name { color: var(--ink-0); }

    /* ════════════════════════════════════════
       RESPONSIVE
       ════════════════════════════════════════ */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: 1.5rem; }
      .hero-photo { order: -1; }
      .photo-wrap { width: 180px; height: 180px; }
      .hero-desc { max-width: none; }
      .slide-body { flex-direction: column; align-items: flex-start; gap: 1rem; padding: 2rem; }
      .slide-cta { align-self: auto; }
      .slider-wrap { height: 75vh; }
    }

    @media (max-width: 640px) {
      .stack-grid { grid-template-columns: repeat(3, 1fr); }
      .slider-wrap { height: 70vh; }
      .slide-title { font-size: 1.4rem; }
      .slide-desc { display: none; }
    }

    @media (max-width: 480px) {
      .stack-grid { grid-template-columns: repeat(2, 1fr); }
      .hero-ctas { flex-direction: column; }
      .btn { justify-content: center; }
    }
  </style>
</head>
<body>
  <Header />
  <main id="main-content">

    <!-- ════ HERO ════ -->
    <section class="hero page-section" aria-labelledby="hero-heading">
      <div class="hero-inner">
        <div class="hero-text">
          <div class="hero-badge" role="status" data-i18n-aria-label="hero.available">
            <span class="badge-dot" aria-hidden="true"></span>
            <span data-i18n="hero.available">Disponible para proyectos</span>
          </div>
          <!-- Ticker: nombre ↔ rol cada 5s -->
          <div class="hero-ticker" aria-label="Joel Cano Sánchez, Desarrollador Web">
            <div class="ticker-item" id="ticker-name">
              <span class="ticker-name" data-i18n="hero.name" id="hero-heading">Joel Cano Sánchez</span>
            </div>
            <div class="ticker-item" id="ticker-role">
              <span class="ticker-role" data-i18n="hero.role">Web Developer</span>
            </div>
          </div>
          <p class="hero-desc" data-i18n="hero.sub">
            I build web applications from end to end: interfaces, APIs,
            databases and deployment. Passionate about clean code and
            solid architectures.
          </p>
          <div class="hero-ctas">
            <a href="/projects" class="btn btn-primary" data-i18n="hero.cta.projects">Ver proyectos →</a>
            <a href="/about"    class="btn btn-ghost"    data-i18n="hero.cta.about">Sobre mí</a>
            <a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer" class="btn btn-ghost" data-i18n="hero.cta.github" aria-label="GitHub (abre en nueva pestaña)">GitHub</a>
            <a href="#contacto" class="btn btn-ghost" data-i18n="hero.cta.contact">Contacto</a>
          </div>
        </div>

        <div class="hero-photo">
          <div class="photo-wrap">
            <div class="photo-inner">
              <img src="/images/joelcano.png" alt="Foto de perfil de Joel Cano Sánchez" width="260" height="260" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ════ SLIDER DE PROYECTOS ════ -->
    <section class="page-section" id="proyectos" aria-labelledby="sec-proyectos">
      <div class="section-head reveal-up" data-reveal>
        <p class="section-label" id="sec-proyectos" data-i18n="home.featured">// Proyectos destacados</p>
      </div>

      {projects.length === 0 ? (
        <p class="empty-projects" data-i18n="home.noProjects">// Aún no hay proyectos publicados.</p>
      ) : (
        <>
          <ul class="proj-list">
            {latestProjects.map((project, i) => {
              const year = project.data.pubDate
                ? new Date(project.data.pubDate).getFullYear()
                : null;
              return (
                <li class="proj-item" data-proj>
                  <a href={`/projects/${project.id}/`} class="proj-card"
                    data-name-es={project.data.name}
                    data-name-en={project.data.nameEn || project.data.name}
                    data-desc-es={project.data.description}
                    data-desc-en={project.data.descriptionEn || project.data.description}
                  >
                    <div class="proj-main">
                      <div class="proj-top">
                        <span class="proj-num">{String(i + 1).padStart(2, '0')}</span>
                        <h3 class="proj-name proj-translatable-name">{project.data.name}</h3>
                      </div>
                      <p class="proj-desc proj-translatable-desc">{project.data.description}</p>
                      {project.data.techs && project.data.techs.length > 0 && (
                        <div class="proj-chips">
                          {project.data.techs.map(t => <span class="proj-chip">{t}</span>)}
                        </div>
                      )}
                    </div>
                    <div class="proj-aside">
                      {year && <span class="proj-year">{year}</span>}
                <span class="proj-arrow" aria-hidden="true">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="7" y1="17" x2="17" y2="7"/>
                          <polyline points="7 7 17 7 17 17"/>
                        </svg>
                      </span>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>

          <div class="proj-footer reveal-fade" data-reveal>
