---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';
import { titulo } from '../components/BaseHead.astro';

const projects = (await getCollection('project')).sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
	return dateB - dateA;
});

const latestProjects = projects.slice(0, 3);

const highlights = [
	'2º DAW con experiencia en becarios (e-Corp Sistemas y Reactivació Badalona).',
	'Full-stack: frontend, backend, APIs REST y bases de datos relacionales.',
	'Proyectos desplegados en Vercel, Render, Railway y GitHub Pages.',
];

const stackMini = ['React', 'Next.js', 'Node.js', 'Laravel', 'MariaDB', 'Astro', 'Git', 'Docker'];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Home | ${titulo}`} description={SITE_DESCRIPTION} />
		<style>
			/* ── Hero ── */
			.hero {
				padding: 1rem 0 0.5rem;
				margin-bottom: 0.5rem;
			}

			.hero-content {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 3em;
			}

			.hero-text {
				flex: 1;
			}

			.greeting {
				font-family: var(--font-mono);
				font-size: 0.9em;
				color: var(--accent);
				margin-bottom: 0.75em;
				letter-spacing: 0.05em;
			}

			.hero h1 {
				font-size: 3em;
				margin-bottom: 0.45em;
				line-height: 1.15;
			}

			.hero-sub {
				color: var(--text-secondary);
				font-size: 1.1em;
				max-width: 520px;
				margin-bottom: 2.25em;
				line-height: 1.8;
			}

			.cta-links {
				display: flex;
				gap: 0.8em;
				flex-wrap: wrap;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.6em 1.2em;
				border-radius: 6px;
				font-family: var(--font-mono);
				font-size: 0.9em;
				text-decoration: none;
				transition: all 0.2s;
				cursor: pointer;
			}

			.btn-primary {
				background: var(--accent);
				color: #0a0e0f;
				border: 1px solid var(--accent);
				font-weight: 600;
			}

			.btn-primary:hover {
				background: var(--accent-dim);
				border-color: var(--accent-dim);
				box-shadow: var(--shadow-glow);
				text-shadow: none;
				color: #0a0e0f;
			}

			.btn-outline {
				background: transparent;
				color: var(--text-secondary);
				border: 1px solid var(--border);
			}

			.btn-outline:hover {
				color: var(--accent);
				border-color: var(--border-hover);
				background: var(--accent-glow);
				text-shadow: none;
			}

			.hero-photo {
				flex: 0 0 260px;
				display: flex;
				justify-content: center;
			}

			.hero-photo img {
				width: 260px;
				height: 260px;
				object-fit: cover;
				border-radius: 12px;
				border: 2px solid var(--border);
				box-shadow: var(--shadow-glow);
				background: var(--bg-card);
			}

			.divider {
				height: 1px;
				background: var(--border);
				margin: var(--section-gap) 0;
			}

			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1em;
				margin-bottom: 2rem;
				flex-wrap: wrap;
			}

			.section-header .section-label {
				margin-bottom: 0;
			}

			.link-more {
				font-family: var(--font-mono);
				font-size: 0.85em;
				color: var(--text-muted);
				text-decoration: none;
				transition: color 0.2s;
			}

			.link-more:hover {
				color: var(--accent);
				text-shadow: none;
			}

			/* ── Proyectos destacados (3 últimos) ── */
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.projects-grid > li {
				display: flex;
				min-width: 0;
			}

			.projects-grid .project-card {
				width: 100%;
			}

			.project-card {
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
				overflow: hidden;
				text-decoration: none;
				color: inherit;
				transition: all 0.25s ease;
				display: flex;
				flex-direction: column;
				position: relative;
			}

			.project-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--accent), transparent);
				opacity: 0;
				transition: opacity 0.25s;
			}

			.project-card:hover {
				border-color: var(--border-hover);
				box-shadow: var(--shadow-glow);
				transform: translateY(-3px);
				text-shadow: none;
			}

			.project-card:hover::before {
				opacity: 1;
			}

			.card-img {
				width: 100%;
				height: 180px;
				object-fit: cover;
				border-radius: 0;
				border: none;
				display: block;
			}

			.card-img-placeholder {
				width: 100%;
				height: 180px;
				background: var(--bg-elevated);
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.card-body {
				padding: 1.35em 1.4em 1.5em;
				flex: 1;
				display: flex;
				flex-direction: column;
			}

			.card-tag {
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--accent);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 0.5em;
			}

			.card-title {
				margin: 0 0 0.5em;
				color: var(--text-primary);
				font-family: var(--font-mono);
				font-size: 1em;
				font-weight: 600;
				line-height: 1.3;
			}

			.card-title::before {
				content: none !important;
			}

			.card-desc {
				margin: 0;
				color: var(--text-muted);
				font-size: 0.87em;
				line-height: 1.65;
				flex: 1;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.card-techs {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35em;
				margin-top: 1em;
			}

			.tech-chip {
				padding: 0.2em 0.6em;
				background: var(--bg-base);
				border: 1px solid var(--border);
				border-radius: 4px;
				font-family: var(--font-mono);
				font-size: 0.75em;
				color: var(--accent);
			}

			.empty-projects {
				padding: 2em;
				text-align: center;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
				color: var(--text-muted);
				font-family: var(--font-mono);
				font-size: 0.9em;
			}

			/* ── Por qué yo ── */
			.highlights {
				list-style: none;
				padding: 0;
				margin: 0 0 1.75em;
				display: flex;
				flex-direction: column;
				gap: 1.15em;
			}

			.highlights li {
				display: flex;
				gap: 0.85em;
				align-items: flex-start;
				color: var(--text-secondary);
				font-size: 0.95em;
				line-height: 1.75;
			}

			.highlights li::before {
				content: '→';
				color: var(--accent);
				font-family: var(--font-mono);
				flex-shrink: 0;
			}

			.about-link {
				font-family: var(--font-mono);
				font-size: 0.88em;
			}

			/* ── Stack mini ── */
			.stack-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.stack-list li {
				padding: 0.3em 0.8em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 4px;
				font-family: var(--font-mono);
				font-size: 0.8em;
				color: var(--text-secondary);
			}

			/* ── CTA final ── */
			.cta-final {
				text-align: center;
				padding: 3em 2.5em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 12px;
			}

			.cta-final h2 {
				font-size: 1.4em;
				margin-bottom: 0.75em;
			}

			.cta-final h2::before {
				content: none;
			}

			.cta-final p {
				color: var(--text-secondary);
				margin-bottom: 1.75em;
				font-size: 0.95em;
				line-height: 1.75;
				max-width: 42ch;
				margin-left: auto;
				margin-right: auto;
			}

			.cta-final .cta-links {
				justify-content: center;
			}

			@media (max-width: 768px) {
				.hero h1 {
					font-size: 2.25em;
				}

				.hero-content {
					flex-direction: column;
					text-align: center;
					gap: 2em;
				}

				.hero-sub {
					max-width: none;
					margin-bottom: 1.75em;
				}

				.cta-links {
					justify-content: center;
				}

				.hero-photo {
					margin-top: 0.5em;
				}

				.hero-photo img {
					width: 200px;
					height: 200px;
				}

				.projects-grid {
					grid-template-columns: 1fr;
					gap: 1.25rem;
				}

				.section-header {
					margin-bottom: 1.5rem;
				}

				.cta-final {
					padding: 2.25em 1.5em;
				}
			}

			@media (max-width: 480px) {
				.hero h1 {
					font-size: 1.9em;
				}

				.hero-photo img {
					width: 180px;
					height: 180px;
				}

			}

			@media (min-width: 769px) and (max-width: 1024px) {
				.projects-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero page-section">
				<div class="hero-content">
					<div class="hero-text">
						<p class="greeting">// Bienvenido a mi portfolio</p>
						<h1>Joel Cano Sánchez</h1>
						<p class="hero-sub">
							Desarrollador <strong>full-stack junior</strong>. Construyo aplicaciones web de
							principio a fin: frontend, APIs, bases de datos y despliegue.
						</p>
						<div class="cta-links">
							<a href="/projects" class="btn btn-primary">Ver proyectos →</a>
							<a href="/about" class="btn btn-outline">Conóceme</a>
							<a href="https://github.com/joelcansan" target="_blank" rel="noopener noreferrer" class="btn btn-outline">GitHub</a>
							<a
								href="https://mail.google.com/mail/u/0/#inbox?compose=DmwnWrRqhSDmLLzgvbLNwCpqvlxgScVFtWCklrDknzJcHhQnzxLrKwThxTMWqbKqbwXVmmpmDcvB"
								target="_blank"
								rel="noopener noreferrer"
								class="btn btn-outline"
							>Contacto</a>
						</div>
					</div>
					<div class="hero-photo">
						<img src="/images/joelcano.png" alt="Foto de Joel Cano Sánchez" width="260" height="260" />
					</div>
				</div>
			</section>

			<div class="divider"></div>

			<!-- Proyectos destacados -->
			<section class="page-section">
				<div class="section-header">
					<p class="section-label">// Proyectos destacados</p>
					{projects.length > 0 && (
						<a href="/projects" class="link-more">Ver todos →</a>
					)}
				</div>

				{projects.length === 0 ? (
					<p class="empty-projects">// Aún no hay proyectos publicados.</p>
				) : (
					<ul class="projects-grid">
						{latestProjects.map((project) => (
							<li>
								<a href={`/projects/${project.id}/`} class="project-card">
									{project.data.heroImage ? (
										<Image
											class="card-img"
											width={400}
											height={180}
											src={project.data.heroImage}
											alt={project.data.name}
										/>
									) : (
										<div class="card-img-placeholder">
											<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
												<rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8M12 17v4" />
											</svg>
										</div>
									)}
									<div class="card-body">
										<p class="card-tag">// proyecto</p>
										<h3 class="card-title">{project.data.name}</h3>
										<p class="card-desc">{project.data.description}</p>
										{project.data.techs && project.data.techs.length > 0 && (
											<div class="card-techs">
												{project.data.techs.slice(0, 3).map((tech) => (
													<span class="tech-chip">{tech}</span>
												))}
												{project.data.techs.length > 3 && (
													<span class="tech-chip">+{project.data.techs.length - 3}</span>
												)}
											</div>
										)}
									</div>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>

			<div class="divider"></div>

			<!-- Por qué yo -->
			<section class="page-section">
				<p class="section-label">// Por qué trabajar conmigo</p>
				<ul class="highlights">
					{highlights.map((item) => <li>{item}</li>)}
				</ul>
				<a href="/about" class="about-link">Leer mi historia completa →</a>
			</section>

			<div class="divider"></div>

			<!-- Stack mini -->
			<section class="page-section">
				<p class="section-label">// Stack principal</p>
				<ul class="stack-list">
					{stackMini.map((tech) => <li>{tech}</li>)}
				</ul>
			</section>

			<div class="divider"></div>

			<!-- CTA final -->
			<section class="cta-final">
				<h2>¿Hablamos?</h2>
				<p>
					Busco seguir creciendo como desarrollador y aportar en proyectos reales.
					Échale un vistazo a mi trabajo o escríbeme.
				</p>
				<div class="cta-links">
					<a href="/projects" class="btn btn-primary">Ver proyectos</a>
					<a
						href="https://mail.google.com/mail/u/0/#inbox?compose=DmwnWrRqhSDmLLzgvbLNwCpqvlxgScVFtWCklrDknzJcHhQnzxLrKwThxTMWqbKqbwXVmmpmDcvB"
						target="_blank"
						rel="noopener noreferrer"
						class="btn btn-outline"
					>Contacto</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
