  <script is:inline>
  (function () {
    /* ─ Ticker hero ─
       Nombre visible 5s → sale arriba, rol entra desde abajo con rebote.
       Rol visible 3s → sale arriba limpio, nombre vuelve desde abajo con rebote.
    ───────────────────── */
    var elName = document.getElementById('ticker-name');
    var elRole = document.getElementById('ticker-role');
    if (!elName || !elRole) return;

    var showing = 'name'; // estado actual

    function showRole() {
      /* Nombre sale hacia arriba */
      elName.classList.add('exit');
      elName.classList.remove('enter');

      /* Rol entra desde abajo con rebote */
      elRole.classList.remove('exit');
      elRole.classList.add('enter');

      showing = 'role';
      /* Volver al nombre después de 2s */
      setTimeout(showName, 2000);
    }

    function showName() {
      /* Rol sale hacia arriba limpio */
      elRole.classList.add('exit');
      elRole.classList.remove('enter');

      /* Nombre vuelve desde abajo */
      elName.classList.remove('exit');
      elName.classList.add('enter');

      showing = 'name';
      /* Volver al rol después de 3s */
      setTimeout(showRole, 2000);
    }

    /* Arrancar: primer cambio a los 3s */
    setTimeout(showRole, 2000);

    /* ─ Traducción de proyectos en la lista ─
       Lee data-name-es/en y data-desc-es/en de cada tarjeta
       y actualiza .proj-translatable-name y .proj-translatable-desc */
    function translateProjects(lang) {
      document.querySelectorAll('.proj-card[data-name-es]').forEach(function (card) {
        var nameEl = card.querySelector('.proj-translatable-name');
        var descEl = card.querySelector('.proj-translatable-desc');
        if (nameEl) nameEl.textContent = card.getAttribute('data-name-' + lang) || card.getAttribute('data-name-es');
        if (descEl) descEl.textContent = card.getAttribute('data-desc-' + lang) || card.getAttribute('data-desc-es');
      });
    }

    /* Ejecutar al cargar con el idioma activo */
    document.addEventListener('DOMContentLoaded', function () {
      var lang = localStorage.getItem('portfolio-lang') || 'es';
      translateProjects(lang);
    });

    /* Enganchar setLanguage para que traduzca también los proyectos */
    var _origSetHome = window.setLanguage;
    window.setLanguage = function (lang) {
      if (_origSetHome) _origSetHome(lang);
      translateProjects(lang);
    };

    /* ─ Scroll reveal genérico ─ */
    var revEls = document.querySelectorAll('[data-reveal]');
    /* ─ Items de proyectos ─ */
    var projItems = document.querySelectorAll('[data-proj]');

    if ('IntersectionObserver' in window) {
      var makeObs = function (threshold) {
        return new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); }
          });
        }, { threshold: threshold, rootMargin: '0px 0px -40px 0px' });
      };

      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      var obsProj = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('revealed'); obsProj.unobserve(e.target); }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -20px 0px' });

      revEls.forEach(function (el) { obs.observe(el); });
      projItems.forEach(function (el) { obsProj.observe(el); });
    } else {
      revEls.forEach(function (el) { el.classList.add('revealed'); });
      projItems.forEach(function (el) { el.classList.add('revealed'); });
    }
  })();
  </script>
</body>
</html>
