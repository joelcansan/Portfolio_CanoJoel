---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION} from '../consts';
import { titulo } from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${titulo} | Home`} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 3em 0 2em;
			}

			.greeting {
				font-family: var(--font-mono);
				font-size: 0.9em;
				color: var(--accent);
				margin-bottom: 0.5em;
				letter-spacing: 0.05em;
			}

			.hero h1 {
				font-size: 3em;
				margin-bottom: 0.3em;
				line-height: 1.1;
			}

			.hero-sub {
				color: var(--text-secondary);
				font-size: 1.1em;
				max-width: 600px;
				margin-bottom: 2em;
			}

			.cta-links {
				display: flex;
				gap: 1em;
				flex-wrap: wrap;
				margin-bottom: 3em;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.6em 1.2em;
				border-radius: 6px;
				font-family: var(--font-mono);
				font-size: 0.9em;
				text-decoration: none;
				transition: all 0.2s;
				cursor: pointer;
			}

			.btn-primary {
				background: var(--accent);
				color: #0a0e0f;
				border: 1px solid var(--accent);
				font-weight: 600;
			}

			.btn-primary:hover {
				background: var(--accent-dim);
				border-color: var(--accent-dim);
				box-shadow: var(--shadow-glow);
				text-shadow: none;
				color: #0a0e0f;
			}

			.btn-outline {
				background: transparent;
				color: var(--text-secondary);
				border: 1px solid var(--border);
			}

			.btn-outline:hover {
				color: var(--accent);
				border-color: var(--border-hover);
				background: var(--accent-glow);
				text-shadow: none;
			}

			.divider {
				height: 1px;
				background: var(--border);
				margin: 2.5em 0;
			}

			.about-block {
				padding: 1.5em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
				margin-bottom: 1.5em;
			}

			.about-block h2 {
				font-size: 1em;
				margin-bottom: 0.8em;
				color: var(--accent);
				letter-spacing: 0.05em;
			}

			.about-block h2::before {
				content: none;
			}

			.about-block p {
				margin: 0;
				font-size: 0.95em;
			}

			.stack-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.stack-list li {
				padding: 0.3em 0.8em;
				background: var(--bg-elevated);
				border: 1px solid var(--border);
				border-radius: 4px;
				font-family: var(--font-mono);
				font-size: 0.8em;
				color: var(--text-secondary);
			}

			.stack-list li::marker {
				content: none;
			}

			.hero-content {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 3em;
			}

			.hero-text {
				flex: 1;
			}

			.hero-photo {
				flex: 0 0 260px;
				display: flex;
				justify-content: center;
			}

			.hero-photo img {
				width: 260px;
				height: 260px;
				object-fit: cover;
				border-radius: 12px;
				border: 2px solid var(--border);
				box-shadow: var(--shadow-glow);
				background: var(--bg-card);
			}

			/* Responsive */
			@media (max-width: 900px) {
				.hero-content {
					flex-direction: column;
					text-align: center;
				}

				.hero-photo {
					margin-top: 1.5em;
				}

				.hero-text {
					text-align: center;
				}
			}

		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<div class="hero-text">
						<p class="greeting">// Bienvenido a mi portfolio</p>
						<h1>Joel Cano Sánchez</h1>
						<p class="hero-sub">
							Desarrollador fullstack apasionado por construir aplicaciones web robustas y escalables.
							Especializado en backend: Node.js, SQL/NoSQL, APIs REST con Laravel o Express y arquitecturas modernas.
						</p>

						<div class="cta-links">
							<a href="/projects" class="btn btn-primary">Ver proyectos →</a>
							<a href="https://github.com/joelcansan" target="_blank" class="btn btn-outline">GitHub</a>
							<a href="https://mail.google.com/mail/u/0/#inbox?compose=DmwnWrRqhSDmLLzgvbLNwCpqvlxgScVFtWCklrDknzJcHhQnzxLrKwThxTMWqbKqbwXVmmpmDcvB" target="_blank" class="btn btn-outline">Contacto</a>
						</div>
					</div>

					<div class="hero-photo">
						<img src="/images/joelcano.png" alt="Foto de Joel Cano Sánchez" />
					</div>
				</div>
			</section>

			<div class="divider"></div>

			<div class="about-block">
				<h2>// Stack principal</h2>
				<ul class="stack-list">
					<li>Node.js</li>
					<li>JavaScript</li>
					<li>SQL / NoSQL</li>
					<li>REST APIs</li>
					<li>Astro</li>
					<li>React</li>
					<li>Next.js</li>
					<li>Git</li>
					<li>Docker</li>
				</ul>
			</div>

			<div class="about-block">
				<h2>// &iquest;Qu&eacute; encontrar&aacute;s aqu&iacute;?</h2>
				<p>
					Proyectos personales desarrollados desde cero, experimentos con nuevas tecnolog&iacute;as
					y soluciones a problemas reales. Todo documentado como parte de mi proceso de
					aprendizaje continuo.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>