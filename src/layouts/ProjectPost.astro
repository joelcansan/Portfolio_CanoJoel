---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'project'>['data'];

const { name, description, heroImage, techs = [], github, demo, pubDate } = Astro.props;
---

<html lang="es">
	<head>
		<BaseHead title={`${name} | Proyecto`} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}

			/* Hero image */
			.hero-image {
				width: 100%;
				max-height: 420px;
				overflow: hidden;
				position: relative;
			}

			.hero-image::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				height: 120px;
				background: linear-gradient(to bottom, transparent, var(--bg-base));
			}

			.hero-image img {
				width: 100%;
				height: 420px;
				object-fit: cover;
				border-radius: 0;
				border: none;
				display: block;
				margin: 0;
			}

			/* Contenedor del contenido */
			.project-content {
				width: 800px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2.5em 1em 4em;
			}

			/* Breadcrumb */
			.breadcrumb {
				font-family: var(--font-mono);
				font-size: 0.8em;
				color: var(--text-muted);
				margin-bottom: 1.5em;
				display: flex;
				align-items: center;
				gap: 0.5em;
			}

			.breadcrumb a {
				color: var(--text-muted);
				text-decoration: none;
				transition: color 0.2s;
			}

			.breadcrumb a:hover {
				color: var(--accent);
				text-shadow: none;
			}

			.breadcrumb span {
				color: var(--accent);
			}

			/* Header del proyecto */
			.project-header {
				margin-bottom: 2em;
				padding-bottom: 2em;
				border-bottom: 1px solid var(--border);
			}

			.project-header h1 {
				font-size: 2.4em;
				margin-bottom: 0.4em;
				line-height: 1.15;
			}

			.project-desc {
				color: var(--text-secondary);
				font-size: 1.05em;
				line-height: 1.7;
				margin-bottom: 1.5em;
			}

			/* Links de acción */
			.project-links {
				display: flex;
				gap: 0.8em;
				flex-wrap: wrap;
				margin-bottom: 1.5em;
			}

			.btn-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.5em 1.1em;
				border-radius: 6px;
				font-family: var(--font-mono);
				font-size: 0.85em;
				font-weight: 500;
				text-decoration: none;
				transition: all 0.2s;
				cursor: pointer;
			}

			.btn-link-primary {
				background: var(--accent);
				color: #0a0e0f;
				border: 1px solid var(--accent);
			}

			.btn-link-primary:hover {
				background: var(--accent-dim);
				border-color: var(--accent-dim);
				box-shadow: var(--shadow-glow);
				text-shadow: none;
				color: #0a0e0f;
			}

			.btn-link-outline {
				background: transparent;
				color: var(--text-secondary);
				border: 1px solid var(--border);
			}

			.btn-link-outline:hover {
				color: var(--accent);
				border-color: var(--border-hover);
				background: var(--accent-glow);
				text-shadow: none;
			}

			/* Stack de tecnologías */
			.techs-section {
				margin-bottom: 2em;
			}

			.techs-label {
				font-family: var(--font-mono);
				font-size: 0.75em;
				color: var(--text-muted);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 0.6em;
			}

			.techs-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.tech-badge {
				padding: 0.3em 0.8em;
				background: var(--bg-elevated);
				border: 1px solid var(--border);
				border-radius: 4px;
				font-family: var(--font-mono);
				font-size: 0.82em;
				color: var(--accent);
				letter-spacing: 0.02em;
			}

			/* Contenido markdown */
			.prose {
				color: var(--text-secondary);
				line-height: 1.8;
			}

			.prose h2 {
				color: var(--text-primary);
				font-family: var(--font-mono);
				font-size: 1.3em;
				margin: 2em 0 0.8em;
				padding-bottom: 0.4em;
				border-bottom: 1px solid var(--border);
			}

			.prose h2::before {
				content: '## ';
				color: var(--accent);
				font-size: 0.9em;
			}

			.prose h3 {
				color: var(--text-primary);
				font-size: 1.1em;
				margin: 1.5em 0 0.5em;
			}

			.prose h3::before {
				content: none;
			}

			.prose p {
				color: var(--text-secondary);
				margin-bottom: 1.2em;
			}

			.prose ul {
				padding-left: 1.2em;
				margin-bottom: 1.2em;
			}

			.prose ul li {
				margin-bottom: 0.4em;
				color: var(--text-secondary);
			}

			.prose ul li::marker {
				color: var(--accent);
				content: '▸ ';
			}

			.prose strong {
				color: var(--text-primary);
				font-weight: 600;
			}

			.prose a {
				color: var(--accent);
				text-decoration: underline;
				text-decoration-color: rgba(0, 255, 136, 0.3);
				text-underline-offset: 3px;
			}

			.prose a:hover {
				text-decoration-color: var(--accent);
				text-shadow: none;
			}

			.prose code {
				font-size: 0.88em;
			}

			@media (max-width: 720px) {
				.project-header h1 {
					font-size: 1.8em;
				}

				.hero-image,
				.hero-image img {
					max-height: 240px;
					height: 240px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			{heroImage && (
				<div class="hero-image">
					<Image width={1200} height={420} src={heroImage} alt={name} />
				</div>
			)}

			<div class="project-content">
				<nav class="breadcrumb">
					<a href="/projects">Proyectos</a>
					<span>/</span>
					<span style="color: var(--text-secondary)">{name}</span>
				</nav>

				<header class="project-header">
					<h1>{name}</h1>
					<p class="project-desc">{description}</p>

					{(github || demo) && (
						<div class="project-links">
							{github && (
								<a href={github} target="_blank" class="btn-link btn-link-outline">
									<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
										<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
									</svg>
									Ver código
								</a>
							)}
							{demo && (
								<a href={demo} target="_blank" class="btn-link btn-link-primary">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
										<polyline points="15 3 21 3 21 9"/>
										<line x1="10" y1="14" x2="21" y2="3"/>
									</svg>
									Ver demo
								</a>
							)}
						</div>
					)}

					{techs && techs.length > 0 && (
						<div class="techs-section">
							<p class="techs-label">// Tecnologías utilizadas</p>
							<ul class="techs-list">
								{techs.map((tech) => (
									<li class="tech-badge">{tech}</li>
								))}
							</ul>
						</div>
					)}
				</header>

				<div class="prose">
					<slot />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
