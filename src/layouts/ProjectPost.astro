---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'project'>['data'];

const { name, nameEn, description, descriptionEn, heroImage, techs = [], github, demo, pubDate } = Astro.props;
---

<html lang="es">
	<head>
		<script is:inline>
			document.documentElement.setAttribute('data-active-lang', localStorage.getItem('portfolio-lang') || 'es');
		</script>
		<BaseHead title={`${name} | Project`} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
				padding-top: 64px;
			}

			/* ═══════════════════════════════════
			   CONTENEDOR PRINCIPAL
			═══════════════════════════════════ */
			.project-content {
				width: 760px;
				max-width: calc(100% - 3em);
				margin: 0 auto;
				padding: 5em 0 8em;
			}

			/* ═══════════════════════════════════
			   BREADCRUMB
			═══════════════════════════════════ */
			.breadcrumb {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-family: var(--font-mono);
				font-size: 0.75em;
				color: var(--text-muted);
				letter-spacing: 0.05em;
				margin-bottom: 4em;
			}

			.breadcrumb a {
				color: var(--text-muted);
				text-decoration: none;
				transition: color 0.2s;
			}

			.breadcrumb a:hover { color: var(--accent); }

			.breadcrumb .sep { opacity: 0.35; }

			/* ═══════════════════════════════════
			   CABECERA DEL PROYECTO
			═══════════════════════════════════ */
			.project-header {
				margin-bottom: 5em;
			}

			/* Etiqueta superior tipo "chip" */
			.project-eyebrow {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: var(--font-mono);
				font-size: 0.72em;
				color: var(--accent);
				letter-spacing: 0.14em;
				text-transform: uppercase;
				margin-bottom: 1.4em;
				opacity: 0.85;
			}

			.project-eyebrow::before {
				content: '';
				display: inline-block;
				width: 18px;
				height: 1px;
				background: var(--accent);
				opacity: 0.6;
			}

			.project-header h1 {
				font-size: clamp(2.2em, 5vw, 3.4em);
				font-weight: 800;
				line-height: 1.08;
				letter-spacing: -0.03em;
				margin-bottom: 1.2em;
				color: var(--text-primary);
			}

			.project-desc {
				font-size: 1.15em;
				line-height: 1.85;
				color: var(--text-secondary);
				max-width: 62ch;
				margin-bottom: 0;
			}

			/* ═══════════════════════════════════
			   BARRA DE METADATOS
			   (links + techs juntos, separados)
			═══════════════════════════════════ */
			.project-meta {
				display: flex;
				flex-direction: column;
				gap: 2.5em;
				margin: 3.5em 0 0;
				padding: 2.5em 0 0;
				border-top: 1px solid var(--border);
			}

			/* Links */
			.project-links {
				display: flex;
				gap: 0.75em;
				flex-wrap: wrap;
			}

			.btn-link {
				display: inline-flex;
				align-items: center;
				gap: 0.45em;
				padding: 0.6em 1.4em;
				border-radius: 8px;
				font-family: var(--font-mono);
				font-size: 0.82em;
				font-weight: 500;
				text-decoration: none;
				transition: all 0.2s;
				letter-spacing: 0.02em;
			}

			.btn-link-primary {
				background: var(--accent);
				color: #0a0e0f;
				border: 1px solid var(--accent);
			}

			.btn-link-primary:hover {
				background: var(--accent-dim);
				border-color: var(--accent-dim);
				box-shadow: var(--shadow-glow);
				text-shadow: none;
				color: #0a0e0f;
			}

			.btn-link-outline {
				background: transparent;
				color: var(--text-secondary);
				border: 1px solid var(--border);
			}

			.btn-link-outline:hover {
				color: var(--accent);
				border-color: var(--border-hover);
				background: var(--accent-glow);
				text-shadow: none;
			}

			/* Tech stack */
			.techs-section {}

			.techs-label {
				font-family: var(--font-mono);
				font-size: 0.7em;
				color: var(--text-muted);
				letter-spacing: 0.12em;
				text-transform: uppercase;
				margin-bottom: 1em;
			}

			.techs-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.tech-badge {
				padding: 0.35em 0.9em;
				background: transparent;
				border: 1px solid var(--border);
				border-radius: 100px;
				font-family: var(--font-mono);
				font-size: 0.78em;
				color: var(--text-secondary);
				letter-spacing: 0.03em;
				transition: all 0.2s;
			}

			.tech-badge:hover {
				border-color: var(--accent);
				color: var(--accent);
			}

			/* ═══════════════════════════════════
			   SEPARADOR VISUAL ANTES DEL PROSE
			═══════════════════════════════════ */
			.prose-divider {
				display: flex;
				align-items: center;
				gap: 1.2em;
				margin: 5em 0 4.5em;
			}

			.prose-divider::before,
			.prose-divider::after {
				content: '';
				flex: 1;
				height: 1px;
				background: var(--border);
			}

			.prose-divider-label {
				font-family: var(--font-mono);
				font-size: 0.68em;
				color: var(--text-muted);
				letter-spacing: 0.18em;
				text-transform: uppercase;
				white-space: nowrap;
			}

			/* ═══════════════════════════════════
			   PROSE — CONTENIDO MARKDOWN
			═══════════════════════════════════ */
			.prose {
				color: var(--text-secondary);
				line-height: 1.95;
			}

			/* Cada h2 actúa como separador de sección */
			.prose h2 {
				position: relative;
				color: var(--text-primary);
				font-family: var(--font-mono);
				font-size: 0.78em;
				font-weight: 600;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--accent);
				margin: 4.5em 0 1.8em;
				padding-bottom: 0;
			}

			.prose h2::before {
				content: '//  ';
				opacity: 0.5;
			}

			/* Línea decorativa debajo del h2 */
			.prose h2::after {
				content: '';
				display: block;
				width: 100%;
				height: 1px;
				background: linear-gradient(to right, var(--border) 0%, transparent 80%);
				margin-top: 1em;
			}

			.prose h3 {
				color: var(--text-primary);
				font-size: 1.05em;
				font-weight: 600;
				margin: 2.5em 0 0.8em;
			}

			.prose p {
				font-size: 1.04em;
				line-height: 1.95;
				color: var(--text-secondary);
				margin-bottom: 1.8em;
				max-width: 68ch;
			}

			/* Lista como tarjetas */
			.prose ul {
				padding: 0;
				margin: 0 0 2.5em;
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 0.4em;
			}

			.prose ul li {
				display: flex;
				align-items: baseline;
				gap: 0.75em;
				font-size: 1.02em;
				line-height: 1.75;
				color: var(--text-secondary);
				padding: 0.85em 1.1em;
				background: var(--bg-elevated, rgba(255,255,255,0.03));
				border: 1px solid var(--border);
				border-radius: 8px;
				transition: border-color 0.2s;
			}

			.prose ul li:hover {
				border-color: var(--border-hover, rgba(255,255,255,0.12));
			}

			.prose ul li::before {
				content: '→';
				color: var(--accent);
				font-family: var(--font-mono);
				font-size: 0.82em;
				flex-shrink: 0;
				opacity: 0.7;
			}

			.prose ul li::marker { content: none; }

			.prose strong {
				color: var(--text-primary);
				font-weight: 600;
			}

			.prose a {
				color: var(--accent);
				text-decoration: underline;
				text-decoration-color: rgba(0,255,136,0.25);
				text-underline-offset: 4px;
				transition: text-decoration-color 0.2s;
			}

			.prose a:hover {
				text-decoration-color: var(--accent);
				text-shadow: none;
			}

			.prose code {
				font-size: 0.86em;
				padding: 0.15em 0.45em;
				background: var(--bg-elevated, rgba(255,255,255,0.06));
				border: 1px solid var(--border);
				border-radius: 4px;
			}

			.prose blockquote {
				border-left: 2px solid var(--accent);
				margin: 2.5em 0;
				padding: 1.25em 1.75em;
				background: var(--bg-elevated, rgba(255,255,255,0.03));
				border-radius: 0 8px 8px 0;
			}

			.prose blockquote p {
				margin-bottom: 0;
				font-size: 0.97em;
				font-style: italic;
				color: var(--text-muted);
			}

			/* ═══════════════════════════════════
			   RESPONSIVE
			═══════════════════════════════════ */
			@media (max-width: 768px) {
				.project-content { padding: 3.5em 0 5em; }
				.project-header { margin-bottom: 3.5em; }
				.project-header h1 { font-size: 2em; }
				.prose-divider { margin: 3.5em 0 3em; }
				.prose h2 { margin: 3.5em 0 1.4em; }
				.project-links { flex-direction: column; }
				.btn-link { justify-content: center; }
			}

			@media (max-width: 480px) {
				.project-content { max-width: calc(100% - 2em); }
				.project-header h1 { font-size: 1.7em; }
				.breadcrumb { margin-bottom: 2.5em; }
				.prose ul li { padding: 0.75em 0.9em; }
			}
		</style>

		<!-- Estilos globales para los bloques bilingues del markdown -->
		<style is:global>
			.lang-en, .lang-es { display: none !important; }
			html[data-active-lang="es"] .lang-es { display: block !important; }
			html[data-active-lang="es"] .lang-en { display: none !important; }
			html[data-active-lang="en"] .lang-en { display: block !important; }
			html[data-active-lang="en"] .lang-es { display: none !important; }
			html:not([data-active-lang]) .lang-es { display: block !important; }
			span.lang-en, span.lang-es { display: none !important; }
			html[data-active-lang="es"] span.lang-es { display: inline !important; }
			html[data-active-lang="en"] span.lang-en { display: inline !important; }
			html:not([data-active-lang]) span.lang-es { display: inline !important; }
		</style>
	</head>

	<body>
		<Header />
		<main id="main-content">
			<div class="project-content">

				<nav class="breadcrumb" aria-label="Navegación de migas">
					<a href="/projects" data-i18n="project.breadcrumb">Proyectos</a>
					<span class="sep" aria-hidden="true">/</span>
					<span aria-current="page">{name}</span>
				</nav>

				<header class="project-header reveal-up">
					<p class="project-eyebrow" data-i18n="project.tag">Proyecto</p>
					<h1 id="proj-title"
						data-name-es={name}
						data-name-en={nameEn || name}>
						{name}
					</h1>
					<p class="project-desc" id="proj-desc"
						data-desc-es={description}
						data-desc-en={descriptionEn || description}>
						{description}
					</p>

					<div class="project-meta">
						{(github || demo) && (
							<div class="project-links">
								{github && (
									<a href={github} target="_blank" rel="noopener noreferrer" class="btn-link btn-link-outline" aria-label="Ver código en GitHub (abre en nueva pestaña)">
									<svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
											<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
										</svg>
										<span data-i18n="project.viewCode">View code</span>
									</a>
								)}
								{demo && (
									<a href={demo} target="_blank" rel="noopener noreferrer" class="btn-link btn-link-primary" aria-label="Ver demo en vivo (abre en nueva pestaña)">
									<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
											<path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
											<polyline points="15 3 21 3 21 9"/>
											<line x1="10" y1="14" x2="21" y2="3"/>
										</svg>
										<span data-i18n="project.viewDemo">Live demo</span>
									</a>
								)}
							</div>
						)}

						{techs && techs.length > 0 && (
							<div class="techs-section">
								<p class="techs-label" data-i18n="project.techsLabel">// Tecnologías utilizadas</p>
								<ul class="techs-list">
									{techs.map((tech) => (
										<li class="tech-badge">{tech}</li>
									))}
								</ul>
							</div>
						)}
					</div>
				</header>

				<!-- Separador visual antes del contenido -->
				<div class="prose-divider reveal-fade">
					<span class="prose-divider-label" id="proj-divider-label" data-i18n="project.aboutLabel">Sobre este proyecto</span>
				</div>

				<div class="prose reveal-up">
					<slot />
				</div>

			</div>
		</main>
		<Footer />

		<script is:inline>
			function applyProjectLang(lang) {
				var title = document.getElementById('proj-title');
				var desc  = document.getElementById('proj-desc');
				var dividerLabel = document.getElementById('proj-divider-label');
				if (title) title.textContent = title.getAttribute('data-name-' + lang) || title.getAttribute('data-name-en') || title.getAttribute('data-name-es');
				if (desc)  desc.textContent  = desc.getAttribute('data-desc-' + lang)  || desc.getAttribute('data-desc-en')  || desc.getAttribute('data-desc-es');
				document.documentElement.lang = lang;
				document.documentElement.setAttribute('data-active-lang', lang);
			}

			document.addEventListener('DOMContentLoaded', function () {
				var lang = localStorage.getItem('portfolio-lang') || 'es';
				applyProjectLang(lang);

				/* Scroll reveal — mismas clases que Home y About */
				var els = document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right, .reveal-fade');
				if ('IntersectionObserver' in window) {
					var obs = new IntersectionObserver(function (entries) {
						entries.forEach(function (e) {
							if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); }
						});
					}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
					els.forEach(function (el) { obs.observe(el); });
				} else {
					els.forEach(function (el) { el.classList.add('revealed'); });
				}
			});

			/* Enganchar el setLanguage global para que también traduzca
			   nombre y descripción dinámica del proyecto */
			var _origSet = window.setLanguage;
			window.setLanguage = function (lang) {
				if (_origSet) _origSet(lang);
				applyProjectLang(lang);
			};
		</script>
	</body>
</html>
